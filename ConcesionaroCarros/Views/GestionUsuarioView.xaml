<UserControl x:Class="ConcesionaroCarros.Views.GestionUsuarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseDown="RootGrid_PreviewMouseDown">
            <Grid Margin="24">
            <TabControl Background="Transparent">
            <TabItem Header="Usuarios">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Content="Agregar usuario"
                                Command="{Binding AgregarUsuarioCommand}"/>
                    </Grid>

                    <DataGrid x:Name="UsuariosDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Usuarios}"
                              SelectedItem="{Binding SelectedUsuario, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#D1D5DB"
                              BorderThickness="1"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              MinHeight="170"
                              MaxHeight="360"
                              HorizontalAlignment="Stretch">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombres" Binding="{Binding Nombres}" Width="1.3*" MinWidth="120"/>
                            <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="1.3*" MinWidth="120"/>
                            <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="2.3*" MinWidth="170"/>
                            <DataGridTextColumn Header="Telefono" Binding="{Binding Telefono}" Width="1.1*" MinWidth="110"/>
                            <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="1.0*" MinWidth="110"/>
                            <DataGridTextColumn Header="Aplicativos" Binding="{Binding AplicativosResumen}" Width="1.8*" MinWidth="160"/>
                            <DataGridTextColumn Header="Fecha Registro" Binding="{Binding FechaRegistro}" Width="1.4*" MinWidth="130"/>

                            <DataGridTemplateColumn Header="Acciones" Width="1.6*" MinWidth="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Content="Editar"
                                                    PreviewMouseDown="AccionButton_PreviewMouseDown"
                                                    Command="{Binding DataContext.EditarUsuarioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>

                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Content="Eliminar"
                                                    PreviewMouseDown="AccionButton_PreviewMouseDown"
                                                    Command="{Binding DataContext.EliminarUsuarioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border x:Name="AsignacionPanel"
                            Grid.Row="2"
                            Style="{StaticResource CardBorder}"
                            Margin="0,14,0,0"
                            Visibility="{Binding IsPanelAsignacionVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource SectionTitle}"
                                       Text="Asignacion de aplicativos y cargo por seccion"/>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Usuario seleccionado"/>
                                    <TextBox Text="{Binding NombreUsuarioAsignacion}"
                                             IsReadOnly="True"
                                             Background="#F9FAFB"
                                             BorderBrush="#D1D5DB"
                                             Height="34"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Cargo actual"/>
                                    <TextBox Text="{Binding SelectedUsuario.Rol}"
                                             IsReadOnly="True"
                                             Background="#F9FAFB"
                                             BorderBrush="#D1D5DB"
                                             Height="34"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,14,0,0" MinHeight="260" MaxHeight="260">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2.2*"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Grid.Column="0" Header="Roles disponibles" Margin="0,0,12,0">
                                    <ItemsControl ItemsSource="{Binding RolesAsignables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Nombre}"
                                                          Margin="0,6,0,2"
                                                          IsEnabled="{Binding EsEditable}"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          Command="{Binding DataContext.SeleccionarRolCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Aplicativos del instalador" MinHeight="240" MaxHeight="260">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <ItemsControl ItemsSource="{Binding AplicativosAsignables}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,6">
                                                        <StackPanel>
                                                            <CheckBox Content="{Binding Nombre}"
                                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                      FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Ruta}"
                                                                       Margin="18,2,0,0"
                                                                       Foreground="#6B7280"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </GroupBox>
                            </Grid>

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,14,0,0">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Cerrar"
                                        Command="{Binding OcultarPanelAsignacionCommand}"/>
                                <Button Style="{StaticResource PrimaryButton}"
                                        Margin="0"
                                        Content="Guardar asignacion"
                                        Command="{Binding GuardarAsignacionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Clientes" Visibility="Collapsed">
                <DataGrid ItemsSource="{Binding Clientes}" IsReadOnly="True"/>
            </TabItem>

            <TabItem Header="Administradores" Visibility="Collapsed">
                <DataGrid ItemsSource="{Binding Empleados}" IsReadOnly="True"/>
            </TabItem>

            <TabItem Header="Ingeniero" Visibility="Collapsed">
                <DataGrid ItemsSource="{Binding Empleados}" IsReadOnly="True"/>
            </TabItem>
            </TabControl>
            </Grid>
        </ScrollViewer>

        <Image Grid.Row="1"
               Source="C:\Users\wandica\source\repos\ConcesionaroCarros\ConcesionaroCarros\Images\6 -Banner  -  Grid para correo 2026.png"
               Width="390"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,34,22"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>

</UserControl>


