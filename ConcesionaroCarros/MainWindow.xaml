<Window x:Class="ConcesionaroCarros.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ConcesionaroCarros.Converters"
        Title="DRIVE &amp; DREAM Elite Automotive Management"
        Height="800" Width="1250"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBool"/>

        <DropShadowEffect x:Key="CardShadow" 
                          BlurRadius="12"
                          ShadowDepth="2" Opacity="0.1" 
                          Color="Black"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuVentaActivo"
               TargetType="Button"
               BasedOn="{StaticResource MenuButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding VistaActiva}" Value="Venta">
                    <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource CorpPanelBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,10">
                    <Image Source="C:\Users\wandica\source\repos\ConcesionaroCarros\ConcesionaroCarros\Images\WEG-Logo.png"
                           Width="92"
                           Height="46"
                           HorizontalAlignment="Left"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,22,0,28" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NombreUsuario}"
                               Foreground="{StaticResource CorpTextBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <TextBlock Text="Estado: Conectado" 
                               Foreground="{StaticResource CorpAccentBrush}" 
                               FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock Text="v2.0.1 - Enterprise Edition" 
                               Foreground="{StaticResource CorpMutedBrush}" 
                               FontSize="9" 
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Button Content="🏠 Dashboard" 
                            Visibility="{Binding SoloInventario, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowDashboardCommand}"/>

                    <Button Content="📦 Instalador" 
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowCarrosCommand}"/>

                    <Button Content="👥 Directorio de Clientes" 
                            Visibility="{Binding SoloInventario, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowClientesCommand}"/>

                    <Button Content="👔 Gestión de Empleados" 
                            Visibility="{Binding SoloInventario, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowEmpleadosCommand}"/>

                    <Button Content="🛠 Gestión de Usuarios"
                            Visibility="{Binding EsAdministrador, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowGestionUsuariosCommand}"/>

                    <Separator Background="{StaticResource CorpBorderBrush}" Margin="20,15"/>
                    <Button Content="💰 Punto de Venta" 
                            Visibility="{Binding SoloInventario, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MenuVentaActivo}"
                            Command="{Binding ShowVentaCommand}"/>

                    <Button Content="📄 Registro de Facturas" 
                            Visibility="{Binding SoloInventario, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowFacturaCommand}"/>

                    <Button Content="🚪 Cerrar sesión"
                            Command="{Binding CerrarSesionCommand}"
                            Style="{StaticResource MenuButtonStyle}"
                            Foreground="{StaticResource CorpDangerBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EEF2F5" Offset="0"/>
                    <GradientStop Color="#DEEAF2" Offset="0.6"/>
                    <GradientStop Color="#D3E4EE" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Margin="45">

                    <TextBlock Text="Dashboard General" 
                               FontSize="34" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource CorpAccentBrush}"/>
                    <TextBlock Text="Resumen ejecutivo y analítica de activos en tiempo real." 
                               FontSize="15" 
                               Foreground="{StaticResource CorpMutedBrush}" 
                               Margin="0,5,0,40"/>

                    <UniformGrid Columns="4" Margin="0,0,0,40">

                        <Border Background="{StaticResource CorpSurfaceBrush}" 
                                CornerRadius="15" 
                                Margin="8" 
                                Padding="25" 
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="🚗 Vehículos Disponibles" 
                                           Foreground="{StaticResource CorpAccentBrush}"
                                           FontSize="11" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="0" 
                                           FontSize="28" 
                                           FontWeight="Black" 
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CorpSurfaceBrush}" 
                                CornerRadius="15" 
                                Margin="8" 
                                Padding="25"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="👥 Clientes Registrados" 
                                           Foreground="{StaticResource CorpAccentDarkBrush}" 
                                           FontSize="11" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="0" 
                                           FontSize="28" 
                                           FontWeight="Black" 
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CorpSurfaceBrush}" 
                                CornerRadius="15"
                                Margin="8" 
                                Padding="25" 
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="👔 Empleados Activos" 
                                           Foreground="{StaticResource CorpTextBrush}" 
                                           FontSize="11" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="0" 
                                           FontSize="28"
                                           FontWeight="Black"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CorpSurfaceBrush}" 
                                CornerRadius="15" 
                                Margin="8" Padding="25"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <TextBlock Text="📄 Facturas Registradas" 
                                           Foreground="{StaticResource CorpAccentSoftBrush}" 
                                           FontSize="11" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="0" 
                                           FontSize="28"
                                           FontWeight="Black" 
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <Border Background="{StaticResource CorpSurfaceBrush}" 
                            CornerRadius="20" 
                            Padding="35" 
                            Margin="0,0,0,40" 
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Análisis Financiero de Activos" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Margin="0,0,0,25" 
                                       Foreground="{StaticResource CorpAccentBrush}"/>

                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="💰 Valorización de Inventario (Real-Time)" 
                                           Foreground="{StaticResource CorpMutedBrush}" FontSize="14"/>
                                <TextBlock Text="$3.850.000.000 COP" 
                                           HorizontalAlignment="Right" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource CorpTextBrush}" 
                                           FontSize="16"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="📈 Rendimiento de Ventas Mensuales" 
                                           Foreground="{StaticResource CorpMutedBrush}" 
                                           FontSize="14"/>
                                <TextBlock Text="$1.250.000.000 COP" 
                                           HorizontalAlignment="Right" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource CorpAccentBrush}" 
                                           FontSize="16"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="⭐ Modelos de Mayor Rentabilidad" 
                                           Foreground="{StaticResource CorpMutedBrush}" 
                                           FontSize="14"/>
                                <TextBlock Text="Audi RS5 Sportback, BMW M4 Competition" 
                                           HorizontalAlignment="Right" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource CorpAccentDarkBrush}" 
                                           FontSize="14"/>
                            </Grid>

                            <Grid>
                                <TextBlock Text="📉 Costos Operativos Estimados" 
                                           Foreground="{StaticResource CorpMutedBrush}" 
                                           FontSize="14"/>
                                <TextBlock Text="$45.200.000 COP" 
                                           HorizontalAlignment="Right" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource CorpDangerBrush}" 
                                           FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CorpPanelBrush}" 
                            CornerRadius="20" 
                            Padding="35" 
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Protocolos de Operación" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,25" 
                                       Foreground="{StaticResource CorpAccentBrush}"/>

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🛒" FontSize="20" 
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Gestión de Activos y Logística" 
                                               Foreground="Black" 
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Optimización de stock premium mediante inspección técnica de 110 puntos y valorización de mercado." 
                                               Foreground="{StaticResource CorpMutedBrush}" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="💳" 
                                           FontSize="20"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Transacciones y Pasarela Financiera" 
                                               Foreground="Black" 
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Control centralizado de flujos de caja, planes de financiación bancaria y cierres de preventa." 
                                               Foreground="{StaticResource CorpMutedBrush}" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📑" FontSize="20" 
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" 
                                            Margin="10,0,0,0">
                                    <TextBlock Text="Cumplimiento Legal y Auditoría" 
                                               Foreground="Black" 
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Seguimiento de facturación electrónica, trámites de tránsito y trazabilidad comercial según normativa." 
                                               Foreground="{StaticResource CorpMutedBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
            <ContentControl x:Name="RootContent"
                Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>

