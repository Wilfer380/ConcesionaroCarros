<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <appSettings>
        <!-- Dominio corporativo requerido -->
        <add key="CC_CORPORATE_EMAIL_DOMAIN" value="weg.net" />

        <!-- En pruebas: false. En produccion empresarial: true -->
        <add key="CC_REQUIRE_MICROSOFT_EMAIL_VALIDATION" value="false" />

        <!-- Configurar en produccion cuando CC_REQUIRE_MICROSOFT_EMAIL_VALIDATION=true -->
        <add key="CC_AZURE_TENANT_ID" value="" />
        <add key="CC_AZURE_CLIENT_ID" value="" />
        <add key="CC_AZURE_CLIENT_SECRET" value="" />

    </appSettings>

    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>
</configuration>
































