<UserControl x:Class="ConcesionaroCarros.Controls.ThemeModeSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
              MinWidth="520"
              MinHeight="140"
              SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="ThemeStateLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#33000000" Opacity="0.22"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemeIconRayStyle" TargetType="Line">
            <Setter Property="StrokeThickness" Value="2.2"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Stroke" Value="{DynamicResource CorpAccentBrush}"/>
        </Style>
        <Style x:Key="ThemeKnobRayStyle" TargetType="Line" BasedOn="{StaticResource ThemeIconRayStyle}">
            <Setter Property="Stroke" Value="{DynamicResource CorpSurfaceBrush}"/>
        </Style>
        <Style x:Key="KnobIconShellStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <RadialGradientBrush RadiusX="0.85" RadiusY="0.85" Center="0.45,0.42" GradientOrigin="0.4,0.35">
                        <GradientStop Color="#FFF9ECD0" Offset="0"/>
                        <GradientStop Color="#FFECCB8A" Offset="0.52"/>
                        <GradientStop Color="#FFD5A857" Offset="1"/>
                    </RadialGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#66D1B06A" Opacity="0.48"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <RadialGradientBrush RadiusX="0.85" RadiusY="0.85" Center="0.45,0.42" GradientOrigin="0.38,0.35">
                                <GradientStop Color="#FFDCE7FF" Offset="0"/>
                                <GradientStop Color="#FF9EB4E6" Offset="0.58"/>
                                <GradientStop Color="#FF5673B6" Offset="1"/>
                            </RadialGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#665B7FBE" Opacity="0.52"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TrackShellStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#22344766" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#1B2635" Offset="0"/>
                                <GradientStop Color="#1A2534" Offset="0.34"/>
                                <GradientStop Color="#20314A" Offset="0.72"/>
                                <GradientStop Color="#2C4272" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#A6D2E2F3" Offset="0"/>
                                <GradientStop Color="#8FB3C8DD" Offset="0.6"/>
                                <GradientStop Color="#8087A3C9" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#2A5B7BB6" Opacity="0.28"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="False">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#F6FAFD" Offset="0"/>
                                <GradientStop Color="#ECF3F8" Offset="0.3"/>
                                <GradientStop Color="#E1EAF3" Offset="0.7"/>
                                <GradientStop Color="#D2DFEA" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#E6FFFFFF" Offset="0"/>
                                <GradientStop Color="#CCCEDDED" Offset="0.5"/>
                                <GradientStop Color="#B3AEC0D6" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#26476486" Opacity="0.18"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="KnobShellStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FBFEFF" Offset="0"/>
                        <GradientStop Color="#F1F6FA" Offset="0.4"/>
                        <GradientStop Color="#E6EEF5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#2EFFFFFF" Opacity="0.34"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#243447" Offset="0"/>
                                <GradientStop Color="#2A3C55" Offset="0.45"/>
                                <GradientStop Color="#324868" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#99A7BFE0"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#22597DB8" Opacity="0.34"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GestureGuideArrowStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#A6D8E6FF"/>
            <Setter Property="StrokeThickness" Value="2.2"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Stretch" Value="Fill"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,10,0,0"
          PreviewMouseMove="OnRootPreviewMouseMove"
          PreviewMouseLeftButtonUp="OnRootPreviewMouseLeftButtonUp"
          LostMouseCapture="OnRootLostMouseCapture">
        <Border
                Height="118"
                Margin="4,34,4,0"
                CornerRadius="59"
                Background="#14000000"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#223F5878" Opacity="0.28"/>
            </Border.Effect>
        </Border>

        <Border x:Name="TrackBorder"
                Height="112"
                Margin="0,34,0,0"
                CornerRadius="56"
                BorderThickness="1.2"
                Style="{StaticResource TrackShellStyle}"
                MouseLeftButtonDown="OnTrackMouseLeftButtonDown">
            <Grid Margin="18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border CornerRadius="48"
                        Margin="2"
                        Background="#11000000"
                        BorderBrush="#14FFFFFF"
                        BorderThickness="1"
                        IsHitTestVisible="False"
                        Grid.ColumnSpan="2"/>
                <Border x:Name="LightStateHost"
                        Grid.Column="0"
                        Margin="10,4,14,4"
                        Padding="24,14"
                        CornerRadius="34"
                        Background="Transparent"
                        IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Viewbox Width="60" Height="60" Stretch="Uniform">
                        <Grid Width="50" Height="50">
                            <Ellipse x:Name="LightStateSunGlow"
                                     Width="29"
                                     Height="29"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0.3"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FFDAB56A" Offset="0"/>
                                        <GradientStop Color="#00DAB56A" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="LightStateSunGlowScale" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Grid x:Name="LightStateSunRays" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="LightStateSunRaysRotate"/>
                                </Grid.RenderTransform>
                                <Canvas Width="40" Height="40">
                                    <Line X1="20" Y1="3.5" X2="20" Y2="8.5" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="20" Y1="31.5" X2="20" Y2="36.5" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="3.5" Y1="20" X2="8.5" Y2="20" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="31.5" Y1="20" X2="36.5" Y2="20" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="8.5" Y1="8.5" X2="12.4" Y2="12.4" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="27.6" Y1="27.6" X2="31.5" Y2="31.5" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="8.5" Y1="31.5" X2="12.4" Y2="27.6" Style="{StaticResource ThemeIconRayStyle}"/>
                                    <Line X1="27.6" Y1="12.4" X2="31.5" Y2="8.5" Style="{StaticResource ThemeIconRayStyle}"/>
                                </Canvas>
                            </Grid>
                            <Ellipse Width="18" Height="18" Fill="{DynamicResource CorpAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="9" Height="9" Fill="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-4,-5,0,0"/>
                        </Grid>
                        </Viewbox>
                        <TextBlock Text="{Binding LightLabel, ElementName=Root}" Margin="12,0,0,0" Style="{StaticResource ThemeStateLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="DarkStateHost"
                        Grid.Column="1"
                        Margin="14,4,10,4"
                        Padding="24,14"
                        CornerRadius="34"
                        Background="Transparent"
                        IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Viewbox Width="60" Height="60" Stretch="Uniform">
                        <Grid Width="50" Height="50">
                            <Ellipse x:Name="DarkStateMoonGlow"
                                     Width="31"
                                     Height="31"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0.34"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#B3FFFFFF" Offset="0"/>
                                        <GradientStop Color="#26FFFFFF" Offset="0.58"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="DarkStateMoonGlowScale" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Canvas x:Name="DarkStateMoonSparkles"
                                    Width="40"
                                    Height="40"
                                    Opacity="0.72"
                                    IsHitTestVisible="False">
                                <Ellipse Width="4" Height="4" Fill="#D9FFFFFF" Canvas.Left="7" Canvas.Top="9"/>
                                <Ellipse Width="3" Height="3" Fill="#99FFFFFF" Canvas.Left="30" Canvas.Top="11"/>
                                <Ellipse Width="2" Height="2" Fill="#66FFFFFF" Canvas.Left="28" Canvas.Top="27"/>
                            </Canvas>
                            <Grid x:Name="DarkStateMoonGroup" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="DarkStateMoonTiltTransform"/>
                                        <TranslateTransform x:Name="DarkStateMoonFloatTransform"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Path Fill="#6A81B8"
                                      Stretch="Uniform"
                                       Width="22"
                                       Height="22"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 11,1 C 7,3.2 4.5,7.4 4.5,12 C 4.5,19 10,24.5 17,24.5 C 19.7,24.5 22.2,23.7 24.2,22.2 C 21.6,22.9 18.5,22.5 15.7,20.8 C 10.4,17.7 8.5,10.9 11,1 Z"/>
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#26FFFFFF"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="7,3,0,0"
                                         IsHitTestVisible="False"/>
                                <Ellipse Width="3.2"
                                         Height="3.2"
                                         Fill="#14000000"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="9,11,0,0"
                                         IsHitTestVisible="False"/>
                                <Ellipse Width="2.4"
                                         Height="2.4"
                                         Fill="#11000000"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="15,7,0,0"
                                         IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                        </Viewbox>
                        <TextBlock Text="{Binding DarkLabel, ElementName=Root}" Margin="12,0,0,0" Style="{StaticResource ThemeStateLabelStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="GestureGuideHandOverlay"
              Width="{Binding ElementName=TrackBorder, Path=ActualWidth}"
              MinWidth="148"
              Height="40"
              Margin="0,156,0,0"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Panel.ZIndex="3"
              IsHitTestVisible="False"
              Opacity="0.9">
            <Viewbox Width="22"
                     Height="22"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stretch="Uniform">
                <Viewbox.Style>
                    <Style TargetType="Viewbox">
                        <Setter Property="LayoutTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="True">
                                <Setter Property="LayoutTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="-1" ScaleY="1"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Viewbox.Style>
                <Grid RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="GestureGuideHandTranslate"/>
                            <ScaleTransform x:Name="GestureGuideHandScale" ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <Path Stretch="Uniform"
                          Data="M 17,3 C 18.6,3 19.8,4.3 19.8,5.8 L 19.8,12.8 L 20.8,12.1 C 22.3,11.1 24.3,11.5 25.3,12.9 C 26.4,14.5 26,16.7 24.4,17.8 L 20.1,20.7 C 18.7,21.7 17,22.2 15.2,22.2 L 11.6,22.2 C 9.4,22.2 7.5,20.5 7.2,18.4 L 5.8,9.6 C 5.5,8.1 6.5,6.6 8,6.2 C 9.6,5.8 11.1,6.7 11.6,8.2 L 12.4,10.4 L 12.4,3.8 C 12.4,2.3 13.6,1 15.1,1 C 16.2,1 17.2,1.8 17.5,2.9 C 17.4,3 17.2,3 17,3 Z M 14.8,3.7 L 14.8,12.7 L 13.6,12.7 L 9.7,8.7 C 9.5,8.4 9.1,8.3 8.8,8.4 C 8.4,8.5 8.1,8.9 8.2,9.4 L 9.6,18.1 C 9.7,19.1 10.6,19.9 11.6,19.9 L 15.2,19.9 C 16.5,19.9 17.8,19.5 18.8,18.8 L 23.1,15.9 C 23.6,15.5 23.8,14.8 23.5,14.4 C 23.2,14 22.5,13.9 22,14.2 L 18.7,16.5 C 18.3,16.7 17.9,16.8 17.5,16.6 C 17.1,16.4 16.8,16 16.8,15.5 L 16.8,5.8 C 16.8,5.1 16.3,4.6 15.8,4.6 C 15.2,4.6 14.8,5.1 14.8,5.8 Z">
                        <Path.Style>
                            <Style TargetType="Path">
                                <!-- Default (dark theme): keep the warm yellow that already pops -->
                                <Setter Property="Fill" Value="#FFF1D38F"/>
                                <Setter Property="Stroke" Value="Transparent"/>
                                <Setter Property="StrokeThickness" Value="0"/>
                                <Setter Property="StrokeLineJoin" Value="Round"/>
                                <Style.Triggers>
                                    <!-- Light theme: make the hand dark (no yellow) so it reads clearly on light background -->
                                    <DataTrigger Binding="{Binding IsDarkThemeSelected, ElementName=Root}" Value="False">
                                        <Setter Property="Fill" Value="#1D2B3A"/>
                                        <Setter Property="Stroke" Value="#0F000000"/>
                                        <Setter Property="StrokeThickness" Value="0.8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                    <Ellipse Width="4.4"
                             Height="4.4"
                             Margin="8.6,5,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#40FFFFFF"/>
                </Grid>
            </Viewbox>
        </Grid>

        <Border x:Name="Knob"
                Width="280"
                Height="94"
                Margin="9,34,9,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                BorderThickness="1.5"
                CornerRadius="47"
                Style="{StaticResource KnobShellStyle}"
                Cursor="Hand"
                MouseLeftButtonDown="OnKnobMouseLeftButtonDown">
            <Border.RenderTransform>
                <TranslateTransform x:Name="KnobTransform"/>
            </Border.RenderTransform>
            <Grid Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="66"
                        Height="66"
                        CornerRadius="33"
                        VerticalAlignment="Center"
                        Style="{StaticResource KnobIconShellStyle}">
                    <Grid>
                        <Viewbox Width="64" Height="64" Stretch="Uniform">
                        <Grid x:Name="LightKnobIcon">
                            <Ellipse x:Name="LightKnobSunGlow"
                                     Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0.52"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#B3FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="LightKnobSunGlowScale" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Grid x:Name="LightKnobSunRays" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="LightKnobSunRaysRotate"/>
                                </Grid.RenderTransform>
                                <Canvas Width="50" Height="50">
                                    <Line X1="23" Y1="6" X2="23" Y2="11" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="23" Y1="35" X2="23" Y2="40" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="6" Y1="23" X2="11" Y2="23" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="35" Y1="23" X2="40" Y2="23" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="11.5" Y1="11.5" X2="15" Y2="15" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="31" Y1="31" X2="34.5" Y2="34.5" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="11.5" Y1="34.5" X2="15" Y2="31" Style="{StaticResource ThemeKnobRayStyle}"/>
                                    <Line X1="31" Y1="15" X2="34.5" Y2="11.5" Style="{StaticResource ThemeKnobRayStyle}"/>
                                </Canvas>
                            </Grid>
                            <Ellipse Width="20" Height="20" Fill="{DynamicResource CorpSurfaceBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="9" Height="9" Fill="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-4,-5,0,0"/>
                        </Grid>
                        </Viewbox>
                        <Viewbox Width="64" Height="64" Stretch="Uniform">
                        <Grid x:Name="DarkKnobIcon" Visibility="Collapsed">
                            <Ellipse x:Name="DarkKnobMoonGlow"
                                     Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0.42"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                        <GradientStop Color="#2EFFFFFF" Offset="0.6"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="DarkKnobMoonGlowScale" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Canvas x:Name="DarkKnobMoonSparkles"
                                    Width="50"
                                    Height="50"
                                    Opacity="0.8"
                                    IsHitTestVisible="False">
                                <Ellipse Width="4" Height="4" Fill="#CCFFFFFF" Canvas.Left="9" Canvas.Top="10"/>
                                <Ellipse Width="3" Height="3" Fill="#99FFFFFF" Canvas.Left="33" Canvas.Top="13"/>
                                <Ellipse Width="2" Height="2" Fill="#73FFFFFF" Canvas.Left="31" Canvas.Top="31"/>
                            </Canvas>
                            <Grid x:Name="DarkKnobMoonGroup" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="DarkKnobMoonTiltTransform"/>
                                        <TranslateTransform x:Name="DarkKnobMoonFloatTransform"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Path Fill="{DynamicResource CorpSurfaceBrush}"
                                      Stretch="Uniform"
                                      Width="22"
                                      Height="22"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 11,1 C 7,3.2 4.5,7.4 4.5,12 C 4.5,19 10,24.5 17,24.5 C 19.7,24.5 22.2,23.7 24.2,22.2 C 21.6,22.9 18.5,22.5 15.7,20.8 C 10.4,17.7 8.5,10.9 11,1 Z"/>
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="#33FFFFFF"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="7,3,0,0"
                                         IsHitTestVisible="False"/>
                                <Ellipse Width="3.2"
                                         Height="3.2"
                                         Fill="#14000000"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="9,11,0,0"
                                         IsHitTestVisible="False"/>
                                <Ellipse Width="2.4"
                                         Height="2.4"
                                         Fill="#10000000"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="15,7,0,0"
                                         IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                        </Viewbox>
                    </Grid>
                </Border>
                <TextBlock x:Name="KnobText"
                           Grid.Column="1"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource CorpTextBrush}"
                           FontSize="19"
                           FontWeight="SemiBold"
                           Text="{Binding LightLabel, ElementName=Root}">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#33000000" Opacity="0.22"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Removed secondary gesture overlay. Only the top hint is used. -->

    </Grid>
</UserControl>
