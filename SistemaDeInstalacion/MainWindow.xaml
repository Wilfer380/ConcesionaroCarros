<Window x:Class="ConcesionaroCarros.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
         Title="{markup:Translate Shell_WindowTitle}"
        Icon="System Installer(01).ico"
        Height="800" Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CorpWindowBrush}">

        <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="25,0,0,0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        <Style x:Key="MenuInstaladoresStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding VistaActiva}" Value="Instaladores">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        <Style x:Key="MenuUsuariosStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding VistaActiva}" Value="Usuarios">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        <Style x:Key="MenuAyudaStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding VistaActiva}" Value="Ayuda">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        <Style x:Key="MenuLogsStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding VistaActiva}" Value="Logs">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="MenuConfiguracionStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding VistaActiva}" Value="Configuracion">
                        <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FooterLanguageComboItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                </Trigger>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FooterLanguageComboStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
                <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="MinWidth" Value="170"/>
                <Setter Property="MaxDropDownHeight" Value="220"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource FooterLanguageComboItemStyle}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="ComboBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4"
                                        TextElement.Foreground="{TemplateBinding Foreground}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Margin="10,0,6,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                          IsHitTestVisible="False"/>

                                        <Path Grid.Column="1"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Fill="{DynamicResource CorpMutedBrush}"
                                              Data="M 0 0 L 4 4 L 8 0 Z"/>
                                    </Grid>
                                </Border>

                                <ToggleButton x:Name="ToggleButton"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ClickMode="Press"
                                              Focusable="False"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <Popup Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Border x:Name="PopupBorder"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            Margin="0,4,0,0"
                                            Background="{DynamicResource CorpPanelBrush}"
                                            BorderBrush="{DynamicResource CorpBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            TextElement.Foreground="{TemplateBinding Foreground}"
                                            Padding="4">
                                        <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                      SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="PopupBorder" Property="MinHeight" Value="42"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CorpPanelBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,10">
                    <Image Source="/Images/WEG-Logo.png"
                           Width="92"
                           Height="46"
                           HorizontalAlignment="Left"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,22,0,28" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NombreUsuario}"
                               Foreground="{DynamicResource CorpTextBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <TextBlock Text="{markup:Translate Shell_ConnectionStatusLabel}"
                               Foreground="{DynamicResource CorpAccentBrush}"
                               FontSize="10"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{markup:Translate Shell_VersionLabel}"
                               Foreground="{DynamicResource CorpMutedBrush}"
                               FontSize="9"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Button Content="{markup:Translate Shell_InstaladoresLabel}"
                            Style="{StaticResource MenuInstaladoresStyle}"
                            Command="{Binding ShowInstaladoresCommand}"/>

                    <Button Content="{markup:Translate Shell_GestionUsuariosLabel}"
                            Visibility="{Binding EsAdministrador, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource MenuUsuariosStyle}"
                            Command="{Binding ShowGestionUsuariosCommand}"/>

                    <Button Content="{markup:Translate Shell_AyudaLabel}"
                            ToolTip="{markup:Translate Shell_AyudaTooltip}"
                            Style="{StaticResource MenuAyudaStyle}"
                            Command="{Binding ShowAyudaCommand}"/>

                    <Button Content="{markup:Translate Shell_LogsLabel}"
                            Visibility="{Binding PuedeVerLogs, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource MenuLogsStyle}"
                            Command="{Binding ShowLogsCommand}"/>

                    <Button Content="{Binding DeveloperAccountsLabel}"
                            ToolTip="{Binding DeveloperAccountsTooltip}"
                            Visibility="{Binding EsSuperAdmin, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding ShowDeveloperAccountsCommand}"/>

                    <Separator Background="{DynamicResource CorpBorderBrush}" Margin="20,15"/>

                    <Button Content="{markup:Translate Shell_ConfiguracionLabel}"
                            Command="{Binding ShowSettingsCommand}"
                            Style="{StaticResource MenuConfiguracionStyle}"/>

                    <Button Content="{markup:Translate Shell_CerrarSesionLabel}"
                            Command="{Binding CerrarSesionCommand}"
                            Style="{StaticResource MenuButtonStyle}"
                            Foreground="{DynamicResource CorpDangerBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource ShellContentBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <ContentControl Grid.Row="0" Content="{Binding CurrentView}" Margin="25,25,25,18"/>

            <Border Grid.Row="1"
                    Background="{DynamicResource CorpPanelBrush}"
                    BorderBrush="{DynamicResource CorpBorderBrush}"
                    BorderThickness="1,1,0,0">
                <Grid Margin="16,0,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="HOMOLOGATION"
                               Foreground="{DynamicResource CorpAccentBrush}"
                               FontStyle="Italic"
                               FontWeight="Bold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"/>

                    <ComboBox Grid.Column="3"
                              VerticalAlignment="Center"
                              Style="{StaticResource FooterLanguageComboStyle}"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>


