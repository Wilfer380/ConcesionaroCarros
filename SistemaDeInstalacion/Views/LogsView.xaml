<UserControl x:Class="ConcesionaroCarros.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="LogsFilterComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsFilterComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource LogsFilterComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False"/>

                                    <Path Grid.Column="1"
                                          Width="10"
                                          Height="6"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 6 L 10 0"
                                          Stroke="{DynamicResource CorpAccentBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Grid>
                            </Border>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,6,0,0"
                                        Background="{DynamicResource CorpSurfaceBrush}"
                                        BorderBrush="{DynamicResource CorpBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsFilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CaretBrush" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                <Setter TargetName="TextBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="LogsSectionCardStyle" TargetType="Border" BasedOn="{StaticResource LogsCardStyle}">
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="LogsHeroCardStyle" TargetType="Border" BasedOn="{StaticResource LogsCardStyle}">
            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="LogsMetricTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource CorpMutedBrush}"/>
        </Style>

        <Style x:Key="LogsMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="LogsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
        </Style>

        <Style x:Key="LogsSectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource CorpMutedBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="LogsActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpAccentDarkBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource LogsActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
        </Style>

        <Style x:Key="LogsBackLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsMiniFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="WARNING">
                    <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="LogsStatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="stable">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="review">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="attention">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="ERROR">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="WARNING">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="VALIDATION">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="limited">
                    <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsStatusPillTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="stable">
                    <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="review">
                    <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="attention">
                    <Setter Property="Foreground" Value="{DynamicResource CorpDangerBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="ERROR">
                    <Setter Property="Foreground" Value="{DynamicResource CorpDangerBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="WARNING">
                    <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="VALIDATION">
                    <Setter Property="Foreground" Value="{DynamicResource CorpAccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="limited">
                    <Setter Property="Foreground" Value="{DynamicResource CorpMutedBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsTrendCellStyle" TargetType="Border">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="stable">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="review">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="attention">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="limited">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsSegmentButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="88"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SegmentBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="stable">
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="review">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="attention">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="limited">
                                <Setter TargetName="SegmentBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SegmentBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status-page like timeline bars (reference: tiny colored blocks). -->
        <Style x:Key="LogsTimelineBarStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="1,0,1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bar"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="stable">
                                <Setter TargetName="Bar" Property="Background" Value="{DynamicResource CorpSuccessBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="review">
                                <Setter TargetName="Bar" Property="Background" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="attention">
                                <Setter TargetName="Bar" Property="Background" Value="{DynamicResource CorpDangerBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="limited">
                                <Setter TargetName="Bar" Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bar" Property="Opacity" Value="0.95"/>
                                <Setter TargetName="Bar" Property="BorderBrush" Value="{DynamicResource CorpTextBrush}"/>
                                <Setter TargetName="Bar" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bar" Property="BorderBrush" Value="{DynamicResource CorpTextBrush}"/>
                                <Setter TargetName="Bar" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsFactCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="LogsStatusIconBubbleStyle" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="stable">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpSuccessBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="review">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="attention">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="limited">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsOutlineBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="stable">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpSuccessBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="review">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                </Trigger>
                <Trigger Property="Tag" Value="attention">
                    <Setter Property="BorderBrush" Value="{DynamicResource CorpDangerBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,30,30,108">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{markup:Translate Logs_Dashboard_HeaderTitle}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CorpAccentBrush}"/>
                        <TextBlock Text="{markup:Translate Logs_Dashboard_HeaderSubtitle}"
                                   FontSize="14"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource CorpMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{markup:Translate Logs_Dashboard_ClearFiltersButton}"
                                Margin="0,0,10,0"
                                Style="{StaticResource LogsSecondaryButtonStyle}"
                                Command="{Binding ClearFiltersCommand}"/>
                        <Button Content="{markup:Translate Logs_RefreshButton}"
                                Style="{StaticResource LogsActionButtonStyle}"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource LogsHeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding ExecutiveStatusTitle}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource CorpTextBrush}"/>
                                <Border DockPanel.Dock="Right"
                                        Tag="{Binding ExecutiveStatusLevel}"
                                        Style="{StaticResource LogsStatusPillStyle}">
                                    <TextBlock Text="{Binding ExecutiveStatusLabel}"
                                               Tag="{Binding ExecutiveStatusLevel}"
                                               Style="{StaticResource LogsStatusPillTextStyle}"/>
                                </Border>
                            </DockPanel>

                            <TextBlock Text="{Binding ExecutiveStatusSummary}"
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource CorpTextBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding ExecutiveStatusDetail}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       TextWrapping="Wrap"/>

                            <WrapPanel Margin="0,14,0,0">
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_WindowLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveWindowLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_CoverageLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveCoverageLabel}"
                                                   Margin="0,4,0,0"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource CorpTextBrush}"
                                                    TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel Width="180">
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_LatestSignalLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveLifeSignLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ExecutiveLifeSignDetail}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel Width="180">
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_HeartbeatLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveHeartbeatLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ExecutiveHeartbeatDetail}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel Width="180">
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_DependenciesLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveDependencyLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ExecutiveDependencyDetail}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,10,8">
                                    <StackPanel Width="180">
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_HealthIncidentsLabel}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding ExecutiveIncidentLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ExecutiveIncidentDetail}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource LogsFactCardStyle}" Width="150" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="{markup:Translate Logs_Dashboard_VisibleEventsMetric}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                    <TextBlock Text="{Binding TotalEventos}" Style="{StaticResource LogsMetricValueStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource LogsFactCardStyle}" Width="150" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="{markup:Translate Logs_ErrorsMetric}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                    <TextBlock Text="{Binding TotalErrores}" Style="{StaticResource LogsMetricValueStyle}" Foreground="{StaticResource CorpDangerBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource LogsFactCardStyle}" Width="150" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="{markup:Translate Logs_WarningsMetric}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                    <TextBlock Text="{Binding TotalAdvertencias}" Style="{StaticResource LogsMetricValueStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource LogsFactCardStyle}" Width="150" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="{markup:Translate Logs_Dashboard_P95LatencyMetric}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                    <TextBlock Text="{Binding LatenciaPercentil95}" Style="{StaticResource LogsMetricValueStyle}" FontSize="20"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource CorpSurfaceBrush}"
                        BorderBrush="{StaticResource CorpBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{markup:Translate Logs_Dashboard_FiltersTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_FiltersSubtitle}"
                                       Style="{StaticResource LogsSectionHintStyle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                        Command="{Binding SetDashboardViewModeCommand}"
                                        CommandParameter="realtime">
                                    <Border CornerRadius="12"
                                            Padding="10,6"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CorpBorderBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRealTimeView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_RealTimeView}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource CorpTextBrush}"/>
                                    </Border>
                                </Button>

                                <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding SetDashboardViewModeCommand}"
                                        CommandParameter="history">
                                    <Border CornerRadius="12"
                                            Padding="10,6"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CorpBorderBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHistoryView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_HistoryView}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource CorpTextBrush}"/>
                                    </Border>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Grid.Row="1">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="{markup:Translate Logs_Dashboard_RangeFilter}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                 <ComboBox Width="180"
                                           Height="34"
                                           Style="{StaticResource LogsFilterComboStyle}"
                                           ItemsSource="{Binding AvailableTimeRanges}"
                                           DisplayMemberPath="DisplayName"
                                           IsEnabled="{Binding IsHistoryView}"
                                           SelectedItem="{Binding SelectedTimeRangeOption, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="{markup:Translate Logs_MachineLabel}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                 <ComboBox Width="180"
                                           Height="34"
                                           Style="{StaticResource LogsFilterComboStyle}"
                                           ItemsSource="{Binding AvailableMachines}"
                                           DisplayMemberPath="DisplayName"
                                           SelectedItem="{Binding SelectedMachineOption, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="{markup:Translate Logs_Dashboard_SeverityFilter}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                 <ComboBox Width="180"
                                           Height="34"
                                           Style="{StaticResource LogsFilterComboStyle}"
                                           ItemsSource="{Binding AvailableSeverities}"
                                           DisplayMemberPath="DisplayName"
                                           SelectedItem="{Binding SelectedSeverityOption, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="{markup:Translate Logs_Dashboard_ModuleFilter}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                 <ComboBox Width="190"
                                           Height="34"
                                           Style="{StaticResource LogsFilterComboStyle}"
                                           ItemsSource="{Binding AvailableSources}"
                                           DisplayMemberPath="DisplayName"
                                           SelectedItem="{Binding SelectedSourceOption, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="{markup:Translate Logs_UserColumn}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                 <ComboBox Width="190"
                                           Height="34"
                                           Style="{StaticResource LogsFilterComboStyle}"
                                           ItemsSource="{Binding AvailableUsers}"
                                           DisplayMemberPath="DisplayName"
                                           SelectedItem="{Binding SelectedUserOption, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="{markup:Translate Logs_Dashboard_SearchFilter}"
                                           Margin="2,0,0,4"
                                           FontSize="11"
                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                <TextBox Width="280"
                                         Height="34"
                                         Style="{StaticResource LogsFilterTextBoxStyle}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,0,0,18">
                    <TextBlock Text="{markup:Translate Logs_Dashboard_ByFamilyTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                    <TextBlock Text="{markup:Translate Logs_Dashboard_ByFamilySubtitle}"
                               Style="{StaticResource LogsSectionHintStyle}"/>

                    <ItemsControl ItemsSource="{Binding StatusSections}" Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="430" Style="{StaticResource LogsSectionCardStyle}">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"/>
                                            <Border DockPanel.Dock="Right"
                                                    Tag="{Binding StatusLevel}"
                                                    Style="{StaticResource LogsStatusPillStyle}">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           Tag="{Binding StatusLevel}"
                                                           Style="{StaticResource LogsStatusPillTextStyle}"/>
                                            </Border>
                                        </DockPanel>

                                        <TextBlock Text="{Binding Summary}"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Detail}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_HistoricalBands}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                            <ItemsControl ItemsSource="{Binding TimelineSegments}" Margin="0,8,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ToggleButton Tag="{Binding StatusLevel}"
                                                                      Style="{StaticResource LogsTimelineBarStyle}"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      MouseEnter="NarrativeSegment_MouseEnter"
                                                                      MouseLeave="NarrativeSegment_MouseLeave"
                                                                      Command="{Binding DataContext.SelectNarrativeSegmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <DockPanel Margin="0,10,0,0" LastChildFill="False">
                                                <TextBlock Text="{markup:Translate Logs_Dashboard_TimelineStart}"
                                                           Foreground="{StaticResource CorpMutedBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{markup:Translate Logs_Dashboard_TimelineNow}"
                                                           DockPanel.Dock="Right"
                                                           Foreground="{StaticResource CorpMutedBrush}"
                                                           FontSize="11"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding Facts}" Margin="0,10,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="122"
                                                            Style="{StaticResource LogsFactCardStyle}"
                                                            Tag="{Binding DataContext.Title, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            MouseEnter="SectionFact_MouseEnter"
                                                            MouseLeave="SectionFact_MouseLeave">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                                            <TextBlock Text="{Binding Value}"
                                                                       Margin="0,5,0,0"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource CorpTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,18,0,0"
                            Background="{StaticResource CorpSurfaceBrush}"
                            BorderBrush="{StaticResource CorpBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18"
                            MouseEnter="NarrativeContextPanel_MouseEnter"
                            MouseLeave="NarrativeContextPanel_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.1*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,18,0">
                                <TextBlock Text="{Binding NarrativeContextEyebrow}"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <DockPanel Margin="0,10,0,0" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Tag="{Binding ContextNarrativeSegment.StatusLevel}"
                                                Style="{StaticResource LogsStatusIconBubbleStyle}">
                                            <TextBlock Text="{Binding NarrativeContextStatusIcon}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource CorpTextBrush}"
                                                       FontSize="16"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <StackPanel Margin="12,0,0,0">
                                            <TextBlock Text="{Binding NarrativeContextTitle}"
                                                       Style="{StaticResource LogsSectionTitleStyle}"/>
                                            <TextBlock Text="{Binding ContextNarrativeSegment.Summary}"
                                                       Margin="0,6,0,0"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding NarrativeContextSeverityBadge}"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,10,0"/>
                                        <TextBlock Text="{Binding NarrativeContextStateBadge}"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="{Binding NarrativeContextStatus}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding ContextNarrativeSegment.Explanation}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <WrapPanel Margin="0,14,0,0">
                                    <Border Style="{StaticResource LogsFactCardStyle}" Width="170">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_NarrativePeriodTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding NarrativeContextPeriodLabel}"
                                                       TextWrapping="Wrap"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource LogsFactCardStyle}" Width="150">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_DurationTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                            <TextBlock Text="{Binding NarrativeContextDurationLabel}"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource LogsFactCardStyle}" Width="150">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_CoverageTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                            <TextBlock Text="{Binding ContextNarrativeSegment.CoverageState}"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource LogsFactCardStyle}" Width="150">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_RecoveryTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                            <TextBlock Text="{Binding ContextNarrativeSegment.RecoveryState}"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{markup:Translate Logs_Dashboard_SegmentFactsTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                <ItemsControl ItemsSource="{Binding ContextNarrativeSegment.Detail.Facts}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Margin="0,4,0,0"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource CorpTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Hint}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{StaticResource CorpMutedBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasNarrativeContextRelatedItems, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{markup:Translate Logs_Dashboard_RelatedIncidentsTitle}"
                                               Style="{StaticResource LogsMetricTitleStyle}"/>
                                    <ItemsControl ItemsSource="{Binding NarrativeContextRelatedItems}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource LogsOutlineBadgeStyle}" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource CorpTextBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="{markup:Translate Logs_Dashboard_ViewRelatedEventsButton}"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource LogsActionButtonStyle}"
                                            Command="{Binding ApplyNarrativeSegmentDrillDownCommand}"
                                            CommandParameter="{Binding ContextNarrativeSegment}"/>
                                    <Button Content="{markup:Translate Logs_Dashboard_ClearContextButton}"
                                            Style="{StaticResource LogsSecondaryButtonStyle}"
                                            Command="{Binding ClearNarrativeSelectionCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,18">
                    <TextBlock Text="{markup:Translate Logs_Dashboard_DistributionsTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                    <TextBlock Text="{markup:Translate Logs_Dashboard_DistributionsSubtitle}"
                               Style="{StaticResource LogsSectionHintStyle}"/>

                    <Border Margin="0,12,0,0"
                            Background="{StaticResource CorpSurfaceBrush}"
                            BorderBrush="{StaticResource CorpBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16"
                            MouseEnter="DashboardHoverPanel_MouseEnter"
                            MouseLeave="DashboardHoverPanel_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.3*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{Binding DashboardHoverCard.Eyebrow}"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <DockPanel Margin="0,10,0,0" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Tag="{Binding DashboardHoverCard.StatusLevel}"
                                                Style="{StaticResource LogsStatusIconBubbleStyle}">
                                            <TextBlock Text="{Binding DashboardHoverCard.StatusIcon}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource CorpTextBrush}"
                                                       FontSize="16"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <StackPanel Margin="12,0,0,0">
                                            <TextBlock Text="{markup:Translate Logs_Dashboard_HoverReadingTitle}"
                                                       Style="{StaticResource LogsSectionTitleStyle}"/>
                                            <TextBlock Text="{Binding DashboardHoverCard.Title}"
                                                       Margin="0,6,0,0"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource CorpTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding DashboardHoverCard.BadgeLabel}"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,10,0"/>
                                        <TextBlock Text="{Binding DashboardHoverCard.SecondaryBadge}"
                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="{Binding DashboardHoverCard.Summary}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource CorpTextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding DashboardHoverCard.Detail}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Translate Logs_Dashboard_DurationOrValidityTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                        <TextBlock Text="{Binding DashboardHoverCard.DurationLabel}"
                                                   Margin="0,4,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource CorpTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding DashboardHoverCard.ActionHint}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource CorpAccentBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>

                                <ItemsControl ItemsSource="{Binding DashboardHoverCard.RelatedItems}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource LogsOutlineBadgeStyle}" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource CorpTextBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding DashboardHoverCard.Facts}"
                                          Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource LogsFactCardStyle}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource LogsMetricTitleStyle}"/>
                                                <TextBlock Text="{Binding Value}"
                                                           Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource CorpTextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Hint}"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource CorpMutedBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <WrapPanel Margin="0,12,0,0">
                        <Border Width="320" Style="{StaticResource LogsSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_SourceActivityTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_SourceActivitySubtitle}" Style="{StaticResource LogsSectionHintStyle}"/>
                                <ItemsControl ItemsSource="{Binding SourceActivity}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                                    Tag="source-activity"
                                                    MouseEnter="MetricBlock_MouseEnter"
                                                    MouseLeave="MetricBlock_MouseLeave"
                                                    Command="{Binding DataContext.ApplySourceFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding FilterValue}">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource CorpTextBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Count}" DockPanel.Dock="Right" Foreground="{StaticResource CorpMutedBrush}"/>
                                                    </DockPanel>
                                                    <ProgressBar Style="{StaticResource LogsProgressBarStyle}"
                                                                 Margin="0,6,0,4"
                                                                 Maximum="{Binding DataContext.SourceActivityMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 Value="{Binding Count}"/>
                                                    <TextBlock Text="{Binding SecondaryText}" Foreground="{StaticResource CorpMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Width="320" Style="{StaticResource LogsSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_UserActivityTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_UserActivitySubtitle}" Style="{StaticResource LogsSectionHintStyle}"/>
                                <ItemsControl ItemsSource="{Binding UserActivity}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                                    Tag="user-activity"
                                                    MouseEnter="MetricBlock_MouseEnter"
                                                    MouseLeave="MetricBlock_MouseLeave"
                                                    Command="{Binding DataContext.ApplyUserFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding FilterValue}">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource CorpTextBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Count}" DockPanel.Dock="Right" Foreground="{StaticResource CorpMutedBrush}"/>
                                                    </DockPanel>
                                                    <ProgressBar Style="{StaticResource LogsProgressBarStyle}"
                                                                 Margin="0,6,0,4"
                                                                 Maximum="{Binding DataContext.UserActivityMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 Value="{Binding Count}"/>
                                                    <TextBlock Text="{Binding SecondaryText}" Foreground="{StaticResource CorpMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Width="320" Style="{StaticResource LogsSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_MachineActivityTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                                <TextBlock Text="{markup:Translate Logs_Dashboard_MachineActivitySubtitle}" Style="{StaticResource LogsSectionHintStyle}"/>
                                <ItemsControl ItemsSource="{Binding MachineActivity}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                                    Tag="machine-activity"
                                                    MouseEnter="MetricBlock_MouseEnter"
                                                    MouseLeave="MetricBlock_MouseLeave"
                                                    Command="{Binding DataContext.ApplyMachineFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding FilterValue}">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource CorpTextBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Count}" DockPanel.Dock="Right" Foreground="{StaticResource CorpMutedBrush}"/>
                                                    </DockPanel>
                                                    <ProgressBar Style="{StaticResource LogsProgressBarStyle}"
                                                                 Margin="0,6,0,4"
                                                                 Maximum="{Binding DataContext.MachineActivityMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 Value="{Binding Count}"/>
                                                    <TextBlock Text="{Binding SecondaryText}" Foreground="{StaticResource CorpMutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Team taxonomy: se oculta hasta que exista instrumentación real -->
                        <Border Width="320" Style="{StaticResource LogsSectionCardStyle}" Visibility="Collapsed"/>
                    </WrapPanel>
                </StackPanel>

                <Grid Grid.Row="5" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.8*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource LogsSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_ObservablePerformanceTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_ObservablePerformanceSubtitle}" Style="{StaticResource LogsSectionHintStyle}"/>
                            <ItemsControl ItemsSource="{Binding LatencyDistribution}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="8"
                                                Background="Transparent"
                                                CornerRadius="8"
                                                Tag="latency-distribution"
                                                MouseEnter="MetricBlock_MouseEnter"
                                                MouseLeave="MetricBlock_MouseLeave">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource CorpTextBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Count}" DockPanel.Dock="Right" Foreground="{StaticResource CorpMutedBrush}"/>
                                                </DockPanel>
                                                <ProgressBar Style="{StaticResource LogsProgressBarStyle}"
                                                             Margin="0,6,0,4"
                                                             Maximum="{Binding DataContext.LatencyDistributionMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="{Binding Count}"/>
                                                <TextBlock Text="{Binding SecondaryText}" Foreground="{StaticResource CorpMutedBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource LogsSectionCardStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_TimelineTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_TimelineSubtitle}" Style="{StaticResource LogsSectionHintStyle}"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="0,10,8,0"
                                        Padding="4,2"
                                        ToolTip="{markup:Translate Logs_Dashboard_TimelineBackTooltip}"
                                        Visibility="{Binding HasTimelineDrillDownContext, Converter={StaticResource BoolToVisibility}}"
                                        Style="{StaticResource LogsBackLinkButtonStyle}"
                                        Command="{Binding ClearTimelineDrillDownCommand}">
                                    <TextBlock Text="←"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource CorpAccentBrush}"/>
                                </Button>

                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" MaxHeight="330">
                                    <ItemsControl ItemsSource="{Binding RecentCriticalEvents}">
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Button Style="{StaticResource LogsMiniFilterButtonStyle}"
                                                    Command="{Binding DataContext.ApplyIncidentDrillDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border BorderBrush="{StaticResource CorpBorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                                   Foreground="{StaticResource CorpMutedBrush}"
                                                                   FontSize="11"/>

                                                        <Border Grid.Column="1"
                                                                HorizontalAlignment="Left"
                                                                Tag="{Binding Level}"
                                                                Style="{StaticResource LogsStatusPillStyle}">
                                                            <TextBlock Text="{Binding Level}"
                                                                       Tag="{Binding Level}"
                                                                       Style="{StaticResource LogsStatusPillTextStyle}"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Source}"
                                                                       Foreground="{StaticResource CorpAccentBrush}"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding UserName}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{StaticResource CorpMutedBrush}"
                                                                       FontSize="11"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3" Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding Message}"
                                                                       Foreground="{StaticResource CorpTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Details}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{StaticResource CorpMutedBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       TextWrapping="NoWrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="6">
                    <Border Background="{StaticResource CorpPanelBrush}"
                            BorderBrush="{StaticResource CorpBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{markup:Translate Logs_Dashboard_StatusTitle}" Style="{StaticResource LogsMetricTitleStyle}"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,5,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource CorpTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding UltimoError}"
                                       Margin="0,7,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource CorpDangerBrush}"/>
                            <TextBlock Text="{Binding InstrumentationStatus}"
                                       Margin="0,7,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CorpSurfaceBrush}"
                            BorderBrush="{StaticResource CorpBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12,12,18,18">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel>
                                    <TextBlock Text="{markup:Translate Logs_Dashboard_FilteredTracesTitle}" Style="{StaticResource LogsSectionTitleStyle}"/>
                                    <TextBlock Text="{markup:Translate Logs_Dashboard_FilteredTracesSubtitle}"
                                               Style="{StaticResource LogsSectionHintStyle}"/>
                                </StackPanel>

                            </DockPanel>

                            <DataGrid x:Name="LogsDataGrid"
                                      ItemsSource="{Binding FilteredEntries}"
                                      Margin="0,12,6,6"
                                      Height="380"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      RowStyle="{StaticResource LogsRowStyle}"
                                      FrozenColumnCount="4"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource CorpSurfaceBrush}"
                                      Foreground="{StaticResource CorpTextBrush}"
                                      BorderBrush="{StaticResource CorpBorderBrush}"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowBackground="{StaticResource CorpSurfaceBrush}"
                                      AlternatingRowBackground="{StaticResource CorpPanelBrush}">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{markup:Translate Logs_DateColumn}" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_LevelColumn}" Binding="{Binding Level}" Width="100" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_MachineColumn}" Binding="{Binding MachineName}" Width="160" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_UserColumn}" Binding="{Binding UserName}" Width="130" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_SourceColumn}" Binding="{Binding Source}" Width="170" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_LatencyColumn}" Binding="{Binding DurationMs}" Width="110" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_MessageColumn}" Binding="{Binding Message}" Width="340" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                    <DataGridTextColumn Header="{markup:Translate Logs_DetailColumn}" Binding="{Binding Details}" Width="900" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Image Source="/Images/6 -Banner  -  Grid para correo 2026.png"
               Width="320"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,16,14"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</UserControl>
