<UserControl x:Class="ConcesionaroCarros.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="LogsFilterComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsFilterComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource LogsFilterComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False"/>

                                    <Path Grid.Column="1"
                                          Width="10"
                                          Height="6"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 6 L 10 0"
                                          Stroke="{DynamicResource CorpAccentBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,6,0,0"
                                        Background="{DynamicResource CorpSurfaceBrush}"
                                        BorderBrush="{DynamicResource CorpBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="LogsMetricTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource CorpMutedBrush}"/>
        </Style>

        <Style x:Key="LogsMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="LogsActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpAccentDarkBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogsCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="30,30,30,108">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{markup:Translate Logs_Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource CorpAccentBrush}"/>
                <TextBlock Text="{markup:Translate Logs_Subtitle}"
                           FontSize="14"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource CorpMutedBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="{markup:Translate Logs_MachineLabel}"
                               Margin="2,0,0,4"
                               FontSize="11"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                    <ComboBox Width="180"
                              Height="34"
                              Style="{StaticResource LogsFilterComboStyle}"
                              ItemsSource="{Binding AvailableMachines}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="MachineName"
                              SelectedValue="{Binding SelectedMachineFilter, Mode=TwoWay}"
                              ToolTip="{markup:Translate Logs_MachineTooltip}"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="{markup:Translate Logs_DateLabel}"
                               Margin="2,0,0,4"
                               FontSize="11"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                    <ComboBox Width="180"
                              Height="34"
                              Style="{StaticResource LogsFilterComboStyle}"
                              IsEnabled="{Binding CanSelectDate}"
                              ItemsSource="{Binding AvailableDates}"
                              SelectedItem="{Binding SelectedDateFilter, Mode=TwoWay}"
                              ToolTip="{markup:Translate Logs_DateTooltip}"/>
                </StackPanel>

                <Button Content="{markup:Translate Logs_RefreshButton}"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource LogsActionButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
            </Grid>

            <WrapPanel Grid.Row="1" Margin="0,0,0,18">
            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="{markup:Translate Logs_EventsMetric}"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalEventos}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="{markup:Translate Logs_ErrorsMetric}"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalErrores}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="{markup:Translate Logs_WarningsMetric}"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalAdvertencias}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="{markup:Translate Logs_MachinesMetric}"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalEquipos}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="220">
                <StackPanel>
                    <TextBlock Text="{markup:Translate Logs_AverageLatencyMetric}"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding LatenciaPromedio}"
                               Style="{StaticResource LogsMetricValueStyle}"
                               FontSize="20"/>
                </StackPanel>
            </Border>
            </WrapPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource CorpPanelBrush}"
                        BorderBrush="{StaticResource CorpBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{markup:Translate Logs_StatusLabel}"
                                   FontSize="12"
                                   Foreground="{StaticResource CorpMutedBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,5,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CorpTextBrush}"/>
                        <TextBlock Text="{Binding UltimoError}"
                                   Margin="0,7,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource CorpDangerBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource CorpSurfaceBrush}"
                        BorderBrush="{StaticResource CorpBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12,12,18,18">
                    <DataGrid x:Name="LogsDataGrid"
                              ItemsSource="{Binding FilteredEntries}"
                              Margin="0,0,6,6"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowStyle="{StaticResource LogsRowStyle}"
                              FrozenColumnCount="4"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource CorpSurfaceBrush}"
                              Foreground="{StaticResource CorpTextBrush}"
                              BorderBrush="{StaticResource CorpBorderBrush}"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowBackground="{StaticResource CorpSurfaceBrush}"
                              AlternatingRowBackground="{StaticResource CorpPanelBrush}">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{markup:Translate Logs_DateColumn}" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_LevelColumn}" Binding="{Binding Level}" Width="90" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_MachineColumn}" Binding="{Binding MachineName}" Width="160" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_UserColumn}" Binding="{Binding UserName}" Width="120" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_SourceColumn}" Binding="{Binding Source}" Width="160" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_LatencyColumn}" Binding="{Binding DurationMs}" Width="110" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_MessageColumn}" Binding="{Binding Message}" Width="320" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                            <DataGridTextColumn Header="{markup:Translate Logs_DetailColumn}" Binding="{Binding Details}" Width="900" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <Image Source="/Images/6 -Banner  -  Grid para correo 2026.png"
               Width="320"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,16,14"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</UserControl>
