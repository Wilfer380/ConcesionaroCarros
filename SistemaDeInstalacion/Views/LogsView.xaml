<UserControl x:Class="ConcesionaroCarros.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="LogsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="LogsMetricTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource CorpMutedBrush}"/>
        </Style>

        <Style x:Key="LogsMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="LogsActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LogsCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogsRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Background" Value="#FFF4F4"/>
                    <Setter Property="Foreground" Value="{StaticResource CorpDangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Centro de logs"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource CorpAccentBrush}"/>
                <TextBlock Text="Consulta errores, latencias y eventos capturados desde los equipos conectados."
                           FontSize="14"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource CorpMutedBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Equipo"
                               Margin="2,0,0,4"
                               FontSize="11"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                    <ComboBox Width="180"
                              Height="34"
                              ItemsSource="{Binding AvailableMachines}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="MachineName"
                              SelectedValue="{Binding SelectedMachineFilter, Mode=TwoWay}"
                              ToolTip="Equipo detectado a partir de los logs del desarrollador"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Fecha del equipo"
                               Margin="2,0,0,4"
                               FontSize="11"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                    <ComboBox Width="180"
                              Height="34"
                              IsEnabled="{Binding CanSelectDate}"
                              ItemsSource="{Binding AvailableDates}"
                              SelectedItem="{Binding SelectedDateFilter, Mode=TwoWay}"
                              ToolTip="Selecciona primero un equipo para ver sus carpetas por fecha"/>
                </StackPanel>

                <Button Content="Actualizar"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource LogsActionButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="1" Margin="0,0,0,18">
            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Eventos"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalEventos}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Errores"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalErrores}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Advertencias"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalAdvertencias}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Equipos"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding TotalEquipos}"
                               Style="{StaticResource LogsMetricValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource LogsCardStyle}" Width="220">
                <StackPanel>
                    <TextBlock Text="Latencia promedio"
                               Style="{StaticResource LogsMetricTitleStyle}"/>
                    <TextBlock Text="{Binding LatenciaPromedio}"
                               Style="{StaticResource LogsMetricValueStyle}"
                               FontSize="20"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CorpPanelBrush}"
                    BorderBrush="{StaticResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Estado"
                               FontSize="12"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,5,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource CorpTextBrush}"/>
                    <TextBlock Text="{Binding UltimoError}"
                               Margin="0,7,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource CorpDangerBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource CorpSurfaceBrush}"
                    BorderBrush="{StaticResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12">
                <DataGrid x:Name="LogsDataGrid"
                          ItemsSource="{Binding FilteredEntries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowStyle="{StaticResource LogsRowStyle}"
                          FrozenColumnCount="4"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Nivel" Binding="{Binding Level}" Width="90" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Equipo" Binding="{Binding MachineName}" Width="160" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="120" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Origen" Binding="{Binding Source}" Width="160" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Latencia (ms)" Binding="{Binding DurationMs}" Width="110" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Mensaje" Binding="{Binding Message}" Width="320" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                        <DataGridTextColumn Header="Detalle" Binding="{Binding Details}" Width="900" ElementStyle="{StaticResource LogsCellTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
