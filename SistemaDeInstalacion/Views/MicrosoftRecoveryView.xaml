<Window x:Class="ConcesionaroCarros.Views.MicrosoftRecoveryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
        Title="{markup:Translate Recovery_WindowTitle}"
        Width="700"
        Height="720"
        MinWidth="700"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource CorpWindowBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="MsTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource CorpTextBrush}"/>
        </Style>

        <Style x:Key="MsPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource CorpTextBrush}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Padding="32"
                CornerRadius="18"
                Background="{StaticResource CorpSurfaceBrush}"
                BorderBrush="{StaticResource CorpBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Grid Width="42" Height="42" HorizontalAlignment="Left" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Rectangle Fill="#F25022" Margin="0,0,2,2"/>
                            <Rectangle Grid.Column="1" Fill="#7FBA00" Margin="2,0,0,2"/>
                            <Rectangle Grid.Row="1" Fill="#00A4EF" Margin="0,2,2,0"/>
                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="2,2,0,0"/>
                        </Grid>

                        <TextBlock Text="Microsoft"
                                   FontSize="34"
                                   Foreground="{StaticResource CorpAccentBrush}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{markup:Translate Recovery_Title}"
                                   FontSize="24"
                                   Margin="0,12,0,6"
                                   Foreground="{StaticResource CorpTextBrush}"/>
                        <TextBlock Text="{markup:Translate Recovery_Subtitle}"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Image Grid.Column="1"
                           Source="/Images/WEG-Logo.png"
                           Width="54"
                           Height="28"
                           Margin="16,8,0,0"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource CorpPanelBrush}"
                        BorderBrush="{StaticResource CorpBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,0,18"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding MensajeEstado}"
                               Foreground="{StaticResource CorpTextBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,4,0">
                    <Grid>
                        <StackPanel Visibility="{Binding IsValidationStep, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{markup:Translate Recovery_RegisteredEmailLabel}"
                                       FontSize="14"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource MsTextBox}"
                                     Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{markup:Translate Recovery_RegisteredEmailTooltip}"/>
                            <CheckBox Content="{markup:Translate Recovery_NotRobotLabel}"
                                      IsChecked="{Binding NoSoyRobot}"
                                      Margin="0,20,0,0"
                                      FontSize="15"
                                      Foreground="{StaticResource CorpTextBrush}"/>
                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{StaticResource CorpPanelBrush}"
                                    BorderBrush="{StaticResource CorpBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Text="{markup:Translate Recovery_ValidationHint}"
                                           Foreground="{StaticResource CorpMutedBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsPasswordStep, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{markup:Translate Recovery_ValidatedEmailLabel}"
                                       FontSize="14"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource MsTextBox}"
                                     Text="{Binding Correo}"
                                     IsReadOnly="True"
                                     Background="{StaticResource CorpSurfaceBrush}"/>
                            <TextBlock Text="{markup:Translate Recovery_CodeLabel}"
                                       FontSize="14"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,18,0,6"/>
                            <TextBox Style="{StaticResource MsTextBox}"
                                     Text="{Binding CodigoVerificacion, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="6"/>
                            <TextBlock Text="{markup:Translate Recovery_NewPasswordLabel}"
                                       FontSize="14"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,18,0,6"/>
                            <PasswordBox x:Name="txtNuevaPassword"
                                         Style="{StaticResource MsPasswordBox}"
                                         PasswordChanged="NuevaPasswordChanged"/>
                            <TextBlock Text="{markup:Translate Recovery_ConfirmPasswordLabel}"
                                       FontSize="14"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,18,0,6"/>
                            <PasswordBox x:Name="txtConfirmarPassword"
                                         Style="{StaticResource MsPasswordBox}"
                                         PasswordChanged="ConfirmarPasswordChanged"/>
                            <TextBlock Text="{markup:Translate Recovery_PasswordHint}"
                                       Foreground="{StaticResource CorpMutedBrush}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Background="{StaticResource CorpPanelBrush}"
                        BorderBrush="{StaticResource CorpBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Margin="0,22,0,0"
                        Padding="18,18,18,18">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsValidationStep, Converter={StaticResource BoolToVis}}">
                            <Button Content="{markup:Translate Common_Cancel}"
                                    Width="118"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"
                                    Command="{Binding CancelarCommand}"/>
                            <Button Content="{markup:Translate Recovery_ValidateButton}"
                                    Width="128"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ValidarIdentidadCommand}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsPasswordStep, Converter={StaticResource BoolToVis}}">
                            <Button Content="{markup:Translate Common_Cancel}"
                                    Width="118"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"
                                    Command="{Binding CancelarCommand}"/>
                            <Button Content="{markup:Translate Common_Back}"
                                    Width="118"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,10,0"
                                    Command="{Binding VolverCommand}"/>
                            <Button Content="{markup:Translate Recovery_ChangePasswordButton}"
                                    Width="170"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding CambiarPasswordCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>


