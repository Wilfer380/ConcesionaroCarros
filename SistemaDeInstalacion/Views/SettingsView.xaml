<UserControl x:Class="ConcesionaroCarros.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ConcesionaroCarros.Controls"
             xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="720">
                <Border Style="{StaticResource SettingsCardStyle}" Padding="28" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="{markup:Translate Settings_Title}"
                                   Foreground="{DynamicResource CorpTextBrush}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{markup:Translate Settings_Subtitle}"
                                   Foreground="{DynamicResource CorpMutedBrush}"
                                   FontSize="14"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}" Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{markup:Translate Settings_AppearanceTitle}"
                                   Foreground="{DynamicResource CorpTextBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1"
                                   Text="{markup:Translate Settings_AppearanceDescription}"
                                   Foreground="{DynamicResource CorpMutedBrush}"
                                   Margin="0,8,0,20"
                                   TextWrapping="Wrap"/>

                        <controls:ThemeModeSlider Grid.Row="2"
                                                  IsDarkThemeSelected="{Binding IsDarkThemeSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  LightLabel="{markup:Translate Settings_LightOption}"
                                                  DarkLabel="{markup:Translate Settings_DarkOption}"
                                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                </Border>
             </StackPanel>
        </ScrollViewer>

        <Image Source="/Images/6 -Banner  -  Grid para correo 2026.png"
               Width="320"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,16,14"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</UserControl>
