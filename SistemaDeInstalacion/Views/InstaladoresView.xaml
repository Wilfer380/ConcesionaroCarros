<UserControl x:Class="ConcesionaroCarros.Views.InstaladoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:ConcesionaroCarros.ViewModels"
             Background="White"
             x:Name="ParentControl">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FolderBtnBase" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0,10,10,0">
                            <Border x:Name="FolderTab"
                                    Width="92"
                                    Height="12"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="14,-8,0,0"
                                    CornerRadius="6,6,0,0"
                                    Background="{StaticResource CorpPanelStrongBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1,1,1,0"/>
                            <Border x:Name="FolderBody"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Margin="0,0,8,0"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <ContentPresenter VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FolderBody" Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FolderBody" Property="Background" Value="{StaticResource CorpAccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Instaladores"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource CorpAccentBrush}"/>
                    <TextBlock Text="Lista de archivos ejecutables registrados"
                               FontSize="14"
                               Foreground="{StaticResource CorpMutedBrush}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Buscar Instalador"
                        HorizontalAlignment="Right"
                        Background="{StaticResource CorpAccentBrush}"
                        Width="150"
                        Height="40"
                        Style="{StaticResource BtnBase}"
                        FontWeight="Bold"
                        Visibility="{Binding PuedeGestionarInstaladores, Converter={StaticResource BoolToVis}}"
                        Command="{Binding BuscarInstaladorCommand}"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,14">

                <Button Content="Punto local de desarrollo planta"
                        Margin="0,0,10,0"
                        Command="{Binding SeleccionarCarpetaCommand}"
                        CommandParameter="Punto local de desarrollo planta">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FolderBtnBase}">
                            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CarpetaLocalSeleccionada}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource CorpAccentDarkBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Desarrollo global"
                        Command="{Binding SeleccionarCarpetaCommand}"
                        CommandParameter="Desarrollo global">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FolderBtnBase}">
                            <Setter Property="Background" Value="{StaticResource CorpPanelBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CarpetaGlobalSeleccionada}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CorpAccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource CorpAccentDarkBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- LISTA DE INSTALADORES -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Instaladores}"
                      BorderThickness="0"
                      Background="Transparent"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemTemplate>
                    <DataTemplate>

                        <Border Background="{StaticResource CorpSurfaceBrush}"
                                CornerRadius="12"
                                Margin="12"
                                Padding="15"
                                Width="455"
                                HorizontalAlignment="Left">

                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="8"
                                                  ShadowDepth="1"
                                                  Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ICONO -->
                                <Border Grid.Column="0"
                                        Background="{StaticResource CorpPanelBrush}"
                                        CornerRadius="8"
                                        Height="80"
                                        Margin="0,0,15,0">

                                    <Grid>
                                        <!-- Fondo EXE -->
                                        <TextBlock Text="EXE"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource CorpBorderBrush}"
                                                   FontSize="20"/>

                                        <!-- Icono real dinamico -->
                                        <Image Source="{Binding Icono}"
                                               Stretch="Uniform"
                                               Margin="10"/>
                                    </Grid>
                                </Border>

                                <!-- INFORMACION -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource CorpTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding Ruta}"
                                               FontSize="11"
                                               Foreground="{StaticResource CorpMutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <!-- BOTONES -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0">

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,0,8">

                                        <Button Content="Ver"
                                                Background="{StaticResource CorpPanelBrush}"
                                                Foreground="{StaticResource CorpTextBrush}"
                                                Width="45"
                                                Height="26"
                                                Style="{StaticResource BtnBase}"
                                                Margin="0,0,5,0"
                                                Command="{Binding DataContext.VerInstaladorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>

                                        <Button Background="{StaticResource CorpAccentBrush}"
                                                Width="30"
                                                Height="30"
                                                Style="{StaticResource BtnBase}"
                                                Margin="0,0,5,0"
                                                ToolTip="Editar"
                                                Visibility="{Binding DataContext.PuedeGestionarInstaladores, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.EditarInstaladorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>

                                        <Button Background="{StaticResource CorpDangerBrush}"
                                                Width="30"
                                                Height="30"
                                                Style="{StaticResource BtnBase}"
                                                ToolTip="Eliminar"
                                                Visibility="{Binding DataContext.PuedeGestionarInstaladores, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.EliminarInstaladorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>

                                    <Button Content="Instalar"
                                            Background="{StaticResource CorpAccentDarkBrush}"
                                            Height="32"
                                            Width="110"
                                            Style="{StaticResource BtnBase}"
                                            FontWeight="Bold"
                                            Command="{Binding DataContext.EjecutarInstaladorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>

        <Image Source="/Images/6 -Banner  -  Grid para correo 2026.png"
               Width="320"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,16,14"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>

    </Grid>
</UserControl>






