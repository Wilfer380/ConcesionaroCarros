<Window x:Class="ConcesionaroCarros.Views.RecoveryCodePopupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codigo de validacion"
        Width="360"
        Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Background="#F3F6FB">
    <Border Margin="16"
            Padding="24"
            Background="White"
            BorderBrush="#D7DEEA"
            BorderThickness="1"
            CornerRadius="16">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Codigo de validacion"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#106EBE"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtCode"
                       Margin="0,18,0,12"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#111827"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Memoriza el codigo y continua con el cambio de contrasena."
                       TextAlignment="Center"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="txtCountdown"
                       Margin="0,18,0,0"
                       TextAlignment="Center"
                       Foreground="#6B7280"/>
        </StackPanel>
    </Border>
</Window>
