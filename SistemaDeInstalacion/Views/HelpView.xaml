<UserControl x:Class="ConcesionaroCarros.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:markup="clr-namespace:ConcesionaroCarros.Markup"
             Background="Transparent">

    <UserControl.Resources>
        <SolidColorBrush x:Key="HelpNavigationPanelBrush" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="HelpNavigationCardBrush" Color="#FCFDFE"/>
        <SolidColorBrush x:Key="HelpSurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HelpPanelBrush" Color="#F5F8FB"/>
        <SolidColorBrush x:Key="HelpBorderBrush" Color="#D6DFEB"/>
        <SolidColorBrush x:Key="HelpTextBrush" Color="#2F3F52"/>
        <SolidColorBrush x:Key="HelpMutedBrush" Color="#6B7E95"/>
        <SolidColorBrush x:Key="HelpAccentBrush" Color="#234F9B"/>
        <SolidColorBrush x:Key="HelpAccentSoftBrush" Color="#E8F0FC"/>
        <SolidColorBrush x:Key="HelpToolbarHoverBrush" Color="#EBF2F8"/>
        <SolidColorBrush x:Key="HelpPlaceholderSurfaceBrush" Color="#F8FBFD"/>
        <SolidColorBrush x:Key="HelpPlaceholderAccentBrush" Color="#E6EEF5"/>
        <SolidColorBrush x:Key="DocumentationComboBoxBackgroundBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="DocumentationComboBoxHoverBrush" Color="#E7EFF6"/>
        <SolidColorBrush x:Key="DocumentationComboBoxSelectedBrush" Color="#DCE8F1"/>
        <SolidColorBrush x:Key="DocumentationComboBoxPopupBrush" Color="#EEF4F8"/>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HelpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="DocumentationComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxSelectedBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocumentationComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource DocumentationComboBoxBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DocumentationComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border x:Name="ComboBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.Column="0"
                                                          Margin="0,0,10,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                          IsHitTestVisible="False"/>

                                         <Path Grid.Column="1"
                                               Width="10"
                                               Height="6"
                                               VerticalAlignment="Center"
                                               Data="M 0 0 L 5 6 L 10 0"
                                                Stroke="{DynamicResource HelpAccentBrush}"
                                               StrokeThickness="1.8"
                                               StrokeStartLineCap="Round"
                                               StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,6,0,0"
                                        Background="{DynamicResource DocumentationComboBoxPopupBrush}"
                                        BorderBrush="{DynamicResource CorpBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource HelpAccentBrush}"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource DocumentationComboBoxHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{DynamicResource HelpSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource HelpAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ToolbarButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolbarButtonBorder" Property="Background" Value="{DynamicResource HelpToolbarHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToolbarButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="CopyContextMenu">
            <MenuItem Header="{markup:Translate Common_Copy}" Command="ApplicationCommands.Copy"/>
        </ContextMenu>

        <Style x:Key="VisibleWhenDocumentSelectedStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedDocument}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenDocumentNotSelectedStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedDocument}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SupportCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=DocumentationQuickAccessCombo, Path=IsDropDownOpen}" Value="True">
                    <Setter Property="Margin" Value="0,232,0,0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="30,30,30,108">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding TituloAyuda}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource HelpAccentBrush}"/>
                <TextBlock Text="{Binding SubtituloAyuda}"
                           FontSize="14"
                           Margin="0,5,0,0"
                           Foreground="{DynamicResource HelpMutedBrush}"/>
            </StackPanel>
        </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="348"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource HelpNavigationPanelBrush}"
                    BorderBrush="{DynamicResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18">
                <ScrollViewer x:Name="SectionsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource SectionCardStyle}"
                                Background="{DynamicResource HelpNavigationCardBrush}"
                                BorderBrush="{DynamicResource CorpBorderBrush}"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="{markup:Translate Help_NavigationTitle}"
                                             FontSize="16"
                                            FontWeight="Bold"
                                             Foreground="{DynamicResource HelpAccentBrush}"/>
                                <TextBlock Text="{markup:Translate Help_NavigationDescription}"
                                             Margin="0,6,0,0"
                                             FontSize="12"
                                             TextWrapping="Wrap"
                                             Foreground="{DynamicResource HelpTextBrush}"/>

                                <Border Margin="0,14,0,0"
                                        Padding="12"
                                        Background="{DynamicResource HelpSurfaceBrush}"
                                        BorderBrush="{DynamicResource CorpBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Translate Help_QuickAccessTitle}"
                                                     FontSize="12"
                                                    FontWeight="SemiBold"
                                                     Foreground="{DynamicResource HelpTextBrush}"/>
                   
                                         <ComboBox x:Name="DocumentationQuickAccessCombo"
                                                   Margin="0,10,0,0"
                                                    MinWidth="240"
                                                    MaxDropDownHeight="220"
                                                    Padding="8,6"
                                                    Style="{StaticResource DocumentationComboBoxStyle}"
                                                    ItemsSource="{Binding SectionOptions}"
                                                    SelectedItem="{Binding SelectedSectionOption, Mode=TwoWay}"
                                                    TextSearch.TextPath="DisplayName">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource CorpTextBrush}"/>
                                                         <TextBlock Text="{Binding Description}"
                                                                    FontSize="11"
                                                                     Foreground="{DynamicResource CorpMutedBrush}"/>
                                                     </StackPanel>
                                                 </DataTemplate>
                                             </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SupportCardStyle}"
                                 Padding="14,12"
                                   Background="{DynamicResource HelpSurfaceBrush}"
                                   BorderBrush="{DynamicResource CorpBorderBrush}"
                                   BorderThickness="1"
                                   CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="{markup:Translate Help_SupportTitle}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HelpTextBrush}"/>
                                <TextBlock Text="{markup:Translate Help_SupportDescription}"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource HelpMutedBrush}"/>
                                <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                    <TextBox ContextMenu="{StaticResource CopyContextMenu}"
                                             IsReadOnlyCaretVisible="True"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="14"
                                             FontWeight="Bold"
                                             Foreground="{DynamicResource HelpAccentBrush}"
                                             MinWidth="180"
                                             Text="{Binding CorreoSoporte, Mode=OneWay}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource HelpSurfaceBrush}"
                    BorderBrush="{DynamicResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource VisibleWhenDocumentSelectedStyle}"
                            Background="{DynamicResource HelpPanelBrush}"
                            BorderBrush="{DynamicResource CorpBorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="16,16,0,0"
                            Padding="18,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Top"
                                        Margin="0,0,16,0">
                                <Button Style="{StaticResource NavigationToolbarButtonStyle}"
                                        ToolTip="{markup:Translate Help_PreviousDocumentTooltip}"
                                        Command="{Binding NavigateBackCommand}"
                                        IsEnabled="{Binding CanNavigateBack}"
                                        Content="←"/>
                                <Button Style="{StaticResource NavigationToolbarButtonStyle}"
                                        ToolTip="{markup:Translate Help_NextDocumentTooltip}"
                                        Command="{Binding NavigateForwardCommand}"
                                        IsEnabled="{Binding CanNavigateForward}"
                                        Content="→"
                                        Margin="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedDocumentTitle}"
                                           FontSize="21"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource HelpAccentBrush}"/>
                                <TextBlock Text="{Binding SelectedDocumentPath}"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource HelpMutedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.RowSpan="2"
                            Style="{StaticResource VisibleWhenDocumentNotSelectedStyle}"
                            Margin="26"
                            Padding="34"
                            Background="{DynamicResource HelpPlaceholderSurfaceBrush}"
                            BorderBrush="{DynamicResource HelpPlaceholderAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid MaxWidth="440"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Width="58"
                                    Height="58"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource HelpAccentSoftBrush}"
                                    BorderBrush="{DynamicResource HelpPlaceholderAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="29">
                                <Viewbox Margin="18">
                                    <Path Data="M3,3 L17,3 L17,21 L3,21 Z M6,8 L14,8 M6,12 L14,12 M6,16 L11,16"
                                          Stroke="{DynamicResource HelpAccentBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0,18,0,0"
                                       Text="{Binding EmptyStateTitle}"
                                       TextAlignment="Center"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource HelpAccentBrush}"/>

                            <StackPanel Grid.Row="2"
                                        Margin="0,12,0,0">
                                <TextBlock Text="{Binding EmptyStateDescription}"
                                           TextAlignment="Center"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource HelpTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                               Grid.Row="1"
                                               Style="{StaticResource VisibleWhenDocumentSelectedStyle}"
                                               Margin="0"
                                                Padding="0"
                                                ContextMenu="{StaticResource CopyContextMenu}"
                                                IsSelectionEnabled="True"
                                                 Background="{DynamicResource HelpSurfaceBrush}"
                                                 Foreground="{DynamicResource HelpTextBrush}"
                                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Auto"
                                                IsToolBarVisible="False"
                                               Document="{Binding SelectedDocumentFlow}"/>
                </Grid>
            </Border>
            </Grid>
        </Grid>

        <Image Source="/Images/6 -Banner  -  Grid para correo 2026.png"
               Width="320"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,16,14"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Panel.ZIndex="0"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</UserControl>
