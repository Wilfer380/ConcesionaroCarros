<UserControl x:Class="ConcesionaroCarros.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="DocumentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DocBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DocBorder" Property="Background" Value="{StaticResource CorpPanelStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CorpAccentSoftBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource CorpAccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ContextMenu x:Key="CopyContextMenu">
            <MenuItem Header="Copiar" Command="ApplicationCommands.Copy"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding TituloAyuda}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource CorpAccentBrush}"/>
                <TextBlock Text="{Binding SubtituloAyuda}"
                           FontSize="14"
                           Margin="0,5,0,0"
                           Foreground="{StaticResource CorpMutedBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CorpPanelBrush}"
                    BorderBrush="{StaticResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Carpetas de documentación"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource CorpAccentBrush}"
                               Margin="0,0,0,12"/>

                    <Border DockPanel.Dock="Bottom"
                            Margin="0,16,0,0"
                            Padding="14,12"
                            Background="{StaticResource CorpSurfaceBrush}"
                            BorderBrush="{StaticResource CorpAccentBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EsAdministrador}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Para cualquier información"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource CorpTextBrush}"/>
                            <TextBlock Text="ponerse en contacto con el siguiente correo electrónico:"
                                       Margin="0,5,0,0"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                            <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                <TextBox ContextMenu="{StaticResource CopyContextMenu}"
                                         IsReadOnlyCaretVisible="True"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         FontWeight="Bold"
                                         Foreground="{StaticResource CorpAccentBrush}"
                                         MinWidth="180"
                                         Text="{Binding CorreoSoporte, Mode=OneWay}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource CorpAccentBrush}"/>
                                                <TextBlock Text="{Binding DisplayPath}"
                                                           FontSize="12"
                                                           Margin="0,4,0,0"
                                                           Foreground="{StaticResource CorpMutedBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Margin="0,6,0,10"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource CorpTextBrush}"/>

                                                <ItemsControl ItemsSource="{Binding Documents}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource DocumentButtonStyle}"
                                                                    ToolTip="Abrir documento"
                                                                    Command="{Binding DataContext.SelectDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <Border Width="28"
                                                                            Height="28"
                                                                            Background="{StaticResource CorpPanelBrush}"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="DOC"
                                                                                   FontSize="10"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource CorpAccentBrush}"/>
                                                                    </Border>

                                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   FontWeight="SemiBold"/>
                                                                        <TextBlock Text="{Binding FileName}"
                                                                                   FontSize="11"
                                                                                   Margin="0,2,0,0"
                                                                                   Foreground="{StaticResource CorpMutedBrush}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Margin="0,2,0,0"
                                    Padding="14,12"
                                    Background="{StaticResource CorpSurfaceBrush}"
                                    BorderBrush="{StaticResource CorpAccentBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EsAdministrador}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="Para cualquier información"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource CorpTextBrush}"/>
                                    <TextBlock Text="ponerse en contacto con el siguiente correo electrónico:"
                                               Margin="0,5,0,0"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource CorpMutedBrush}"/>
                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                        <TextBox ContextMenu="{StaticResource CopyContextMenu}"
                                                 IsReadOnlyCaretVisible="True"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="14"
                                                 FontWeight="Bold"
                                                 Foreground="{StaticResource CorpAccentBrush}"
                                                 MinWidth="180"
                                                 Text="{Binding CorreoSoporte, Mode=OneWay}"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource CorpSurfaceBrush}"
                    BorderBrush="{StaticResource CorpBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource CorpPanelBrush}"
                            BorderBrush="{StaticResource CorpBorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="16,16,0,0"
                            Padding="18,16">
                        <TextBlock Text="{Binding SelectedDocumentTitle}"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CorpAccentBrush}"/>
                    </Border>

                    <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                              Grid.Row="1"
                                              Margin="0"
                                              Padding="0"
                                              ContextMenu="{StaticResource CopyContextMenu}"
                                              IsSelectionEnabled="True"
                                              VerticalScrollBarVisibility="Auto"
                                              IsToolBarVisible="False"
                                              Document="{Binding SelectedDocumentFlow}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
