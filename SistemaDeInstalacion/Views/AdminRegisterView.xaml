<Window x:Class="ConcesionaroCarros.Views.AdminRegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WEG Installer Systems - Registro Administrador" Height="840" Width="520"
        MinHeight="840" MinWidth="520" MaxHeight="840" MaxWidth="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FrostyInput" TargetType="Control">
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource CorpTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{StaticResource CorpSurfaceBrush}"
                                CornerRadius="15"
                                BorderBrush="{StaticResource CorpBorderBrush}"
                                BorderThickness="1.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdminRegisterComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CorpPanelStrongBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdminRegisterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource CorpTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CorpSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorpBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AdminRegisterComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="15"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False"/>

                                    <Path Grid.Column="1"
                                          Width="10"
                                          Height="6"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 6 L 10 0"
                                          Stroke="{DynamicResource CorpAccentBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Grid>
                            </Border>

                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,6,0,0"
                                        Background="{DynamicResource CorpSurfaceBrush}"
                                        BorderBrush="{DynamicResource CorpBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="15"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource CorpPanelBrush}"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CorpAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="480"
                Height="800"
                CornerRadius="40"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MouseLeftButtonDown="RegisterShell_MouseLeftButtonDown"
                BorderBrush="{StaticResource CorpBorderBrush}"
                BorderThickness="3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{Binding Color, Source={StaticResource CorpAuthHeaderBrush}}" Offset="0"/>
                    <GradientStop Color="{Binding Color, Source={StaticResource CorpAuthHeaderBrush}}" Offset="0.38"/>
                    <GradientStop Color="{Binding Color, Source={StaticResource CorpAuthPanelBrush}}" Offset="0.381"/>
                    <GradientStop Color="{Binding Color, Source={StaticResource CorpAuthPanelBrush}}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="45"
                                  Color="{Binding Color, Source={StaticResource CorpBorderBrush}}"
                                  ShadowDepth="0"
                                  Opacity="0.45"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="252"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="-40,-40,-40,-24"
                        CornerRadius="36,36,0,0"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush ImageSource="/Images/unnamed.jpg"
                                    Stretch="UniformToFill"
                                    AlignmentX="Center"
                                    AlignmentY="Center"/>
                    </Border.Background>
                </Border>

                <Image Grid.Row="0"
                       Source="/Images/logo Weg Blanco.png"
                       Width="210"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-26,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <Grid HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-30,-18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="30"
                            Height="30"
                            Margin="0,0,6,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="MinimizeWindow_Click">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseWindow_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <Button Grid.Row="0"
                        Content="&lt; Volver"
                        Width="120"
                        Height="30"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-8,0,0,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="{DynamicResource CorpBorderBrush}"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Command="{Binding VolverLoginCommand}"/>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Top"
                            Margin="0,-30,0,0">

                     <TextBlock Text="Correo"
                                Foreground="{StaticResource CorpTextBrush}"
                                Margin="10,0,0,5"
                                FontSize="16"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox x:Name="txtCorreoAdmin"
                                 Style="{StaticResource FrostyInput}"
                                 Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="administrador@weg.net"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCorreoAdmin}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCorreoAdmin}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                     <TextBlock Text="Rol"
                                Foreground="{StaticResource CorpTextBrush}"
                                Margin="10,0,0,5"
                                FontSize="16"/>
                    <ComboBox Height="45"
                              Margin="0,0,0,14"
                              ItemsSource="{Binding RolesDisponibles}"
                              SelectedItem="{Binding Rol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="False"
                              FontSize="16"
                              Style="{StaticResource AdminRegisterComboBoxStyle}"/>

                     <TextBlock Text="Contrasena normal"
                                Foreground="{StaticResource CorpTextBrush}"
                                Margin="10,0,0,5"
                                FontSize="16"/>
                    <Grid Margin="0,0,0,14">
                        <PasswordBox Style="{StaticResource FrostyInput}"
                                     x:Name="txtPasswordNormal"
                                     Tag=""
                                     PasswordChanged="PasswordNormalChanged"/>
                        <TextBox Style="{StaticResource FrostyInput}"
                                 x:Name="txtPasswordNormalVisible"
                                 Visibility="Collapsed"
                                 TextChanged="PasswordNormalVisibleChanged"/>
                        <TextBlock Text="***********"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,44,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordNormal}" Value="Visible"/>
                                                <Condition Binding="{Binding Tag, ElementName=txtPasswordNormal}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordNormalVisible}" Value="Visible"/>
                                                <Condition Binding="{Binding Text, ElementName=txtPasswordNormalVisible}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ToggleButton Width="30"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Checked="ShowPasswordNormal_Checked"
                                      Unchecked="ShowPasswordNormal_Unchecked">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE890;"
                                       FontSize="16"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                        </ToggleButton>
                    </Grid>

                     <TextBlock Text="Contrasena administrador"
                                Foreground="{StaticResource CorpTextBrush}"
                                Margin="10,0,0,5"
                                FontSize="16"/>
                    <Grid>
                        <PasswordBox Style="{StaticResource FrostyInput}"
                                     x:Name="txtPasswordAdmin"
                                     Tag=""
                                     PasswordChanged="PasswordAdminChanged"/>
                        <TextBox Style="{StaticResource FrostyInput}"
                                 x:Name="txtPasswordAdminVisible"
                                 Visibility="Collapsed"
                                 TextChanged="PasswordAdminVisibleChanged"/>
                        <TextBlock Text="***********"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,44,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordAdmin}" Value="Visible"/>
                                                <Condition Binding="{Binding Tag, ElementName=txtPasswordAdmin}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordAdminVisible}" Value="Visible"/>
                                                <Condition Binding="{Binding Text, ElementName=txtPasswordAdminVisible}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ToggleButton Width="30"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Checked="ShowPasswordAdmin_Checked"
                                      Unchecked="ShowPasswordAdmin_Unchecked">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE890;"
                                       FontSize="16"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                        </ToggleButton>
                    </Grid>

                    <Button Content="Registrar administrador"
                            Margin="0,28,0,10"
                            Height="55"
                            Width="320"
                            Foreground="{StaticResource CorpAccentBrush}"
                            FontWeight="Bold"
                            FontSize="20"
                            Cursor="Hand"
                            Command="{Binding RegistrarAdminCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBdr"
                                         CornerRadius="27"
                                         BorderBrush="{StaticResource CorpBorderBrush}"
                                         BorderThickness="1.2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{Binding Color, Source={StaticResource CorpSurfaceBrush}}" Offset="0"/>
                                            <GradientStop Color="{Binding Color, Source={StaticResource CorpPanelBrush}}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


