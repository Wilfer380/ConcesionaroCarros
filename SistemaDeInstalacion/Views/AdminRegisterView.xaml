<Window x:Class="ConcesionaroCarros.Views.AdminRegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WEG Installer Systems - Registro Administrador" Height="840" Width="520"
        MinHeight="840" MinWidth="520" MaxHeight="840" MaxWidth="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FrostyInput" TargetType="Control">
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{StaticResource CorpSurfaceBrush}"
                                CornerRadius="15"
                                BorderBrush="{StaticResource CorpBorderBrush}"
                                BorderThickness="1.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="480"
                Height="800"
                CornerRadius="40"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MouseLeftButtonDown="RegisterShell_MouseLeftButtonDown"
                BorderBrush="{StaticResource CorpBorderBrush}"
                BorderThickness="3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F3F5F7" Offset="0"/>
                    <GradientStop Color="#F3F5F7" Offset="0.38"/>
                    <GradientStop Color="#7BA7CC" Offset="0.381"/>
                    <GradientStop Color="#7BA7CC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="45"
                                  Color="#B6CAD9"
                                  ShadowDepth="0"
                                  Opacity="0.45"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="252"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="-40,-40,-40,-24"
                        CornerRadius="36,36,0,0"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush ImageSource="/Images/unnamed.jpg"
                                    Stretch="UniformToFill"
                                    AlignmentX="Center"
                                    AlignmentY="Center"/>
                    </Border.Background>
                </Border>

                <Image Grid.Row="0"
                       Source="/Images/logo Weg Blanco.png"
                       Width="210"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-26,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <Grid HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-30,-18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="30"
                            Height="30"
                            Margin="0,0,6,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="MinimizeWindow_Click">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseWindow_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <Button Grid.Row="0"
                        Content="&lt; Volver"
                        Width="120"
                        Height="30"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-8,0,0,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="White"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Command="{Binding VolverLoginCommand}"/>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Top"
                            Margin="0,-30,0,0">

                    <TextBlock Text="Correo"
                               Foreground="White"
                               Margin="10,0,0,5"
                               FontSize="16"/>
                    <Grid Margin="0,0,0,14">
                        <TextBox x:Name="txtCorreoAdmin"
                                 Style="{StaticResource FrostyInput}"
                                 Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="administrador@weg.net"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCorreoAdmin}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCorreoAdmin}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock Text="Rol"
                               Foreground="White"
                               Margin="10,0,0,5"
                               FontSize="16"/>
                    <ComboBox Height="45"
                              Margin="0,0,0,14"
                              ItemsSource="{Binding RolesDisponibles}"
                              SelectedItem="{Binding Rol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="False"
                              BorderBrush="{StaticResource CorpBorderBrush}"
                              BorderThickness="1.5"
                              Background="White"
                              FontSize="16"
                              Padding="8,4"/>

                    <TextBlock Text="Contrasena normal"
                               Foreground="White"
                               Margin="10,0,0,5"
                               FontSize="16"/>
                    <Grid Margin="0,0,0,14">
                        <PasswordBox Style="{StaticResource FrostyInput}"
                                     x:Name="txtPasswordNormal"
                                     Tag=""
                                     PasswordChanged="PasswordNormalChanged"/>
                        <TextBox Style="{StaticResource FrostyInput}"
                                 x:Name="txtPasswordNormalVisible"
                                 Visibility="Collapsed"
                                 TextChanged="PasswordNormalVisibleChanged"/>
                        <TextBlock Text="***********"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,44,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordNormal}" Value="Visible"/>
                                                <Condition Binding="{Binding Tag, ElementName=txtPasswordNormal}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordNormalVisible}" Value="Visible"/>
                                                <Condition Binding="{Binding Text, ElementName=txtPasswordNormalVisible}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ToggleButton Width="30"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Checked="ShowPasswordNormal_Checked"
                                      Unchecked="ShowPasswordNormal_Unchecked">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE890;"
                                       FontSize="16"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                        </ToggleButton>
                    </Grid>

                    <TextBlock Text="Contrasena administrador"
                               Foreground="White"
                               Margin="10,0,0,5"
                               FontSize="16"/>
                    <Grid>
                        <PasswordBox Style="{StaticResource FrostyInput}"
                                     x:Name="txtPasswordAdmin"
                                     Tag=""
                                     PasswordChanged="PasswordAdminChanged"/>
                        <TextBox Style="{StaticResource FrostyInput}"
                                 x:Name="txtPasswordAdminVisible"
                                 Visibility="Collapsed"
                                 TextChanged="PasswordAdminVisibleChanged"/>
                        <TextBlock Text="***********"
                                   Foreground="{StaticResource CorpMutedBrush}"
                                   Margin="18,0,44,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordAdmin}" Value="Visible"/>
                                                <Condition Binding="{Binding Tag, ElementName=txtPasswordAdmin}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Visibility, ElementName=txtPasswordAdminVisible}" Value="Visible"/>
                                                <Condition Binding="{Binding Text, ElementName=txtPasswordAdminVisible}" Value=""/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ToggleButton Width="30"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Checked="ShowPasswordAdmin_Checked"
                                      Unchecked="ShowPasswordAdmin_Unchecked">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE890;"
                                       FontSize="16"
                                       Foreground="{StaticResource CorpMutedBrush}"/>
                        </ToggleButton>
                    </Grid>

                    <Button Content="Registrar administrador"
                            Margin="0,28,0,10"
                            Height="55"
                            Width="320"
                            Foreground="{StaticResource CorpAccentBrush}"
                            FontWeight="Bold"
                            FontSize="20"
                            Cursor="Hand"
                            Command="{Binding RegistrarAdminCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBdr"
                                        CornerRadius="27"
                                        BorderBrush="#D3E1EB"
                                        BorderThickness="1.2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#F7FAFC" Offset="0"/>
                                            <GradientStop Color="#E9EFF4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


