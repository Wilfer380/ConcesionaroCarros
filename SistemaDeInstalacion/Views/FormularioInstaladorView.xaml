<UserControl x:Class="ConcesionaroCarros.Views.FormularioInstaladorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8FBFE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#A9C6DD"/>
        </Style>

        <Style x:Key="ModernCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F8FBFE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#A9C6DD"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#66000000">
        <Border Width="560"
                MaxHeight="740"
                CornerRadius="20"
                Background="#FDFEFE"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#BBD4E7" CornerRadius="20,20,0,0" Padding="28,18,28,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding TituloFormulario, FallbackValue='Nuevo Instalador'}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CorpAccentBrush}"
                                   VerticalAlignment="Center"/>

                        <Image Grid.Column="1"
                               Source="/Images/WEG-Logo.png"
                               Width="54"
                               Height="28"
                               Margin="0,0,12,0"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <Button Grid.Column="2"
                                Content="X"
                                Command="{Binding CerrarCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource CorpAccentBrush}"
                                FontSize="24"
                                Width="34"
                                Height="34"
                                Cursor="Hand"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Margin="28,0,28,10"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Ruta del instalador" FontSize="14" Margin="0,0,0,5" Foreground="#4B5563"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding Instalador.Ruta}"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernInput}"/>

                            <Button Grid.Column="1"
                                    Content="BUSCAR APP"
                                    Command="{Binding BuscarArchivoCommand}"
                                    Margin="10,0,0,0"
                                    Padding="15,0"
                                    Height="42"
                                    Background="{StaticResource CorpAccentBrush}"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    IsEnabled="{Binding PuedeEditar}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <TextBlock Text="Guardar en carpeta" FontSize="14" Margin="0,0,0,5" Foreground="#4B5563"/>
                        <ComboBox
                                  Margin="0,0,0,20"
                                  ItemsSource="{Binding CarpetasDisponibles}"
                                  SelectedItem="{Binding Instalador.Carpeta}"
                                  IsEnabled="{Binding PuedeEditar}"
                                  Style="{StaticResource ModernCombo}"/>

                        <Border Width="100" Height="100" Background="#EEF4F8" BorderBrush="#A9C6DD" BorderThickness="1" CornerRadius="15" Margin="0,0,0,20">
                            <Grid>
                                <TextBlock Text="EXE"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#A9C6DD"/>
                                <Image Source="{Binding Instalador.Icono}" Stretch="Uniform" Margin="15"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="Nombre del aplicativo" FontSize="14" Margin="0,0,0,5" Foreground="#4B5563"/>
                        <TextBox Text="{Binding Instalador.Nombre}"
                                 IsReadOnly="{Binding EsSoloLectura}"
                                 Margin="0,0,0,20"
                                 Style="{StaticResource ModernInput}"/>

                        <TextBlock Text="Detalles adicionales" FontSize="14" Margin="0,0,0,5" Foreground="#4B5563"/>
                        <TextBox Text="{Binding Instalador.Descripcion}"
                                 IsReadOnly="{Binding EsSoloLectura}"
                                 Height="120"
                                 Padding="10"
                                 Margin="0,0,0,8"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Background="#F8FBFE"
                                 BorderThickness="1.5"
                                 BorderBrush="#A9C6DD"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="#EEF4F8"
                        BorderBrush="#DCE8F1"
                        BorderThickness="0,1,0,0"
                        Padding="20,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Guardar Instalador"
                                Command="{Binding GuardarCommand}"
                                Height="45"
                                MinWidth="170"
                                Background="{StaticResource CorpAccentBrush}"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="16"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Visibility="{Binding EsNuevo, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Guardar Cambios"
                                Command="{Binding GuardarCommand}"
                                Height="45"
                                MinWidth="170"
                                Background="{StaticResource CorpAccentBrush}"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="16"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Visibility="{Binding EsEdicion, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Cancelar"
                                Command="{Binding CerrarCommand}"
                                Height="45"
                                Width="120"
                                Background="#DCE8F1"
                                Foreground="{StaticResource CorpTextBrush}"
                                BorderBrush="#A9C6DD"
                                BorderThickness="1"
                                FontWeight="Bold"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>


